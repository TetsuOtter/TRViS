<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
	xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
	xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
	xmlns:viewmodels="clr-namespace:TRViS.ViewModels"
	x:Class="TRViS.OriginalTimetable.OriginalTimetableV4Page"
	x:DataType="viewmodels:OriginalTimetableViewModel"
	Title="ダイヤ表 (V4)"
	BackgroundColor="{AppThemeBinding Light={StaticResource OT_Bg_Light}, Dark={StaticResource OT_Bg_Dark}}">
	<Grid Padding="16">
		<Label
			HorizontalOptions="Center"
			VerticalOptions="Center"
			TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"
			Text="{Binding ActiveTrain.TrainNumber, StringFormat='V4 Next Big - {0}'}"/>
	</Grid>
</ContentPage>
