<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
	xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
	xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
	xmlns:local="clr-namespace:TRViS.OriginalTimetable"
	xmlns:controls="clr-namespace:TRViS.Controls"
	x:Class="TRViS.OriginalTimetable.OriginalTimetableV1Page"
	x:Name="Self"
	Title="ダイヤ表 (V1)"
	SizeChanged="OnRootSizeChanged"
	BackgroundColor="{AppThemeBinding Light={StaticResource OT_Bg_Light}, Dark={StaticResource OT_Bg_Dark}}">
	<!--
		BindableLayout-based refactor (Apple Swift ObservationTracking workaround,
		swiftlang#84228). The previous implementation used <CollectionView> inside
		<DataTemplate> with a SwipeView + HtmlAutoDetectLabel per row; on iOS
		simulators this trips an ObservationTracking._AccessList /
		_NativeDictionary.copy use-after-free during cell recycling.

		New shape:
		  ContentPage.Content = Grid (RootGrid)
		    |
		    +- Grid (TabletGrid, >=600pt only)
		    |    +- Border  : sticky header (train type / number / dest / car / max)
		    |    +- Label   : empty-state
		    |    +- ScrollView (Tablet body)
		    |         +- VerticalStackLayout (TabletRowsHost)
		    |              BindableLayout.ItemsSource = Items
		    |              BindableLayout.ItemTemplate = DataTemplate(local:V1RowTablet)
		    |
		    +- Grid (CompactGrid, <600pt only) - mirrors TabletGrid at smaller scale
		    |    +- ScrollView (Compact body)
		    |         +- VerticalStackLayout (CompactRowsHost)
		    |              BindableLayout.ItemsSource = Items
		    |              BindableLayout.ItemTemplate = DataTemplate(local:V1RowCompact)
		    |
		    +- Grid (MemoSheetOverlay)   <- overlay layer

		Page-scoped commands (CycleMarker, ClearMarker, OpenMemo, ToggleNote,
		OpenMarkerPopover) are reachable from V1Row* via a Parent-walk; no
		commands are bound through the row's BindingContext. The MarkerPopover
		is not declared as a static overlay - TR.Maui.AnchorPopover instantiates
		it dynamically anchored to the badge view (same pattern as before).
	-->
	<Grid x:Name="RootGrid" AutomationId="OriginalTimetable.V1.Root">

		<!-- ===== Tablet layout (>= 600pt) ===== -->
		<Grid
			x:Name="TabletGrid"
			AutomationId="OriginalTimetable.V1.TabletGrid"
			RowDefinitions="Auto,*"
			IsVisible="False">

			<!-- Sticky train-info header (3 sections, mirrors design v1.jsx) -->
			<Border
				Grid.Row="0"
				AutomationId="OriginalTimetable.V1.Header"
				Background="{StaticResource OT_Bg}"
				Stroke="{StaticResource OT_Rule}"
				StrokeThickness="0,0,0,1"
				Padding="14,10"
				StrokeShape="Rectangle">
				<VerticalStackLayout Spacing="0">
					<Grid ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="8" Padding="0,0,0,6">
						<Border Grid.Column="0" AutomationId="OriginalTimetable.V1.Tablet.FlyoutToggle" WidthRequest="44" HeightRequest="44" Padding="0" StrokeThickness="0" BackgroundColor="Transparent" VerticalOptions="Center">
							<Border.GestureRecognizers><TapGestureRecognizer Tapped="OnFlyoutToggleTapped"/></Border.GestureRecognizers>
							<Label Text="&#xE5D2;" FontFamily="MaterialIconsRegular" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
						</Border>
						<Label Grid.Column="1" AutomationId="OriginalTimetable.V1.Header.Depot" Text="{Binding DepotName, Source={x:Reference Self}}" FontSize="15" VerticalOptions="Center" LineBreakMode="TailTruncation" TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
						<HorizontalStackLayout Grid.Column="2" Spacing="2" VerticalOptions="Center" IsVisible="{Binding HasMultipleTrains, Source={x:Reference Self}}">
							<Border AutomationId="OriginalTimetable.V1.Header.PrevTrain" Padding="4,0" StrokeThickness="0" BackgroundColor="Transparent">
								<Border.GestureRecognizers><TapGestureRecognizer Tapped="OnPrevTrainTapped"/></Border.GestureRecognizers>
								<Label Text="&#xE5CB;" FontFamily="MaterialIconsRegular" FontSize="20" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
							</Border>
							<Border Padding="6,2" StrokeThickness="1" Stroke="{StaticResource OT_Rule}" Background="{StaticResource OT_BgSoft}" StrokeShape="RoundRectangle 99" VerticalOptions="Center">
								<HorizontalStackLayout Spacing="4" VerticalOptions="Center" BindableLayout.ItemsSource="{Binding PagerDots, Source={x:Reference Self}}">
									<BindableLayout.ItemTemplate>
										<DataTemplate>
											<Border HeightRequest="6" WidthRequest="6" StrokeThickness="0" Background="{StaticResource OT_RuleStrong}" StrokeShape="RoundRectangle 3" VerticalOptions="Center">
												<Border.Triggers>
													<DataTrigger TargetType="Border" Binding="{Binding}" Value="True">
														<Setter Property="WidthRequest" Value="18"/>
														<Setter Property="Background" Value="{StaticResource OT_Accent}"/>
													</DataTrigger>
												</Border.Triggers>
											</Border>
										</DataTemplate>
									</BindableLayout.ItemTemplate>
								</HorizontalStackLayout>
							</Border>
							<Border AutomationId="OriginalTimetable.V1.Header.NextTrain" Padding="4,0" StrokeThickness="0" BackgroundColor="Transparent">
								<Border.GestureRecognizers><TapGestureRecognizer Tapped="OnNextTrainTapped"/></Border.GestureRecognizers>
								<Label Text="&#xE5CC;" FontFamily="MaterialIconsRegular" FontSize="20" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
							</Border>
						</HorizontalStackLayout>
						<Label Grid.Column="3" AutomationId="OriginalTimetable.V1.Header.RouteName" Text="{Binding RouteNameText, Source={x:Reference Self}}" FontSize="17" FontAttributes="Bold" HorizontalOptions="End" VerticalOptions="Center" LineBreakMode="TailTruncation" TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
					</Grid>
					<BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource OT_Rule_Light}, Dark={StaticResource OT_Rule_Dark}}"/>
					<Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12" Padding="0,10,0,12">
						<Border Grid.Column="0" AutomationId="OriginalTimetable.V1.Header.TypeChip" Background="{StaticResource OT_Accent}" Padding="10,4" StrokeThickness="0" StrokeShape="RoundRectangle 4" IsVisible="{Binding HasHeaderType, Source={x:Reference Self}}" VerticalOptions="Center">
							<Label Text="{Binding HeaderTypeText, Source={x:Reference Self}}" FontSize="17" FontAttributes="Bold" LineBreakMode="NoWrap" TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"/>
						</Border>
						<Label Grid.Column="1" AutomationId="OriginalTimetable.V1.Header.TrainNumber" Text="{Binding HeaderTrainNumberText, Source={x:Reference Self}}" FontSize="36" FontAttributes="Bold" FontFamily="Menlo" LineBreakMode="NoWrap" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
						<VerticalStackLayout Grid.Column="2" Spacing="0" VerticalOptions="Center">
							<Label Text="両数" FontSize="13" HorizontalOptions="End" TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
							<Label AutomationId="OriginalTimetable.V1.Header.CarCount" Text="{Binding HeaderCarCountText, Source={x:Reference Self}}" FontSize="18" FontAttributes="Bold" HorizontalOptions="End" TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
						</VerticalStackLayout>
						<VerticalStackLayout Grid.Column="3" Spacing="0" VerticalOptions="Center">
							<Label Text="最高速度" FontSize="13" HorizontalOptions="End" TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
							<Label AutomationId="OriginalTimetable.V1.Header.MaxSpeed" Text="{Binding HeaderMaxSpeedText, Source={x:Reference Self}}" FontSize="18" FontAttributes="Bold" FontFamily="Menlo" HorizontalOptions="End" TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
						</VerticalStackLayout>
					</Grid>
					<BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource OT_Rule_Light}, Dark={StaticResource OT_Rule_Dark}}"/>
					<Grid ColumnDefinitions="Auto,*,Auto" Padding="0,6,0,0">
						<VerticalStackLayout Grid.Column="0" Spacing="0">
							<Label Text="現在時刻" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
							<Label AutomationId="OriginalTimetable.V1.Header.Clock" Text="{Binding CurrentTimeText, Source={x:Reference Self}}" FontSize="28" FontAttributes="Bold" FontFamily="Menlo" TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
						</VerticalStackLayout>
						<Label Grid.Column="2" AutomationId="OriginalTimetable.V1.Header.OriginDest" Text="{Binding OriginDestText, Source={x:Reference Self}}" FontSize="14" VerticalOptions="End" HorizontalOptions="End" LineBreakMode="TailTruncation" TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
					</Grid>
				</VerticalStackLayout>
			</Border>
			<!-- Empty-state when ActiveTrain is null -->
			<Label
				Grid.Row="1"
				AutomationId="OriginalTimetable.V1.EmptyState"
				IsVisible="{Binding HasNoActiveTrain, Source={x:Reference Self}}"
				Text="列車を選択してください"
				FontSize="16"
				HorizontalOptions="Center"
				VerticalOptions="Center"
				TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>

			<!-- Row list - BindableLayout host (replaces CollectionView) -->
			<ScrollView
				x:Name="TabletScroll"
				Grid.Row="1"
				AutomationId="OriginalTimetable.V1.RowsList"
				IsVisible="{Binding HasActiveTrain, Source={x:Reference Self}}">
				<VerticalStackLayout
					x:Name="TabletRowsHost"
					Spacing="0"
					BindableLayout.ItemsSource="{Binding Items, Source={x:Reference Self}}">
					<BindableLayout.ItemTemplate>
						<DataTemplate>
							<local:V1RowTablet/>
						</DataTemplate>
					</BindableLayout.ItemTemplate>
				</VerticalStackLayout>
			</ScrollView>
		</Grid>

		<!-- ===== Compact layout (< 600pt) ===== -->
		<Grid
			x:Name="CompactGrid"
			AutomationId="OriginalTimetable.V1.Compact.Root"
			RowDefinitions="Auto,*"
			IsVisible="True">

			<!-- Sticky train-info header (3 sections, mirrors design v1.jsx) -->
			<Border
				Grid.Row="0"
				AutomationId="OriginalTimetable.V1.Compact.Header"
				Background="{StaticResource OT_Bg}"
				Stroke="{StaticResource OT_Rule}"
				StrokeThickness="0,0,0,1"
				Padding="14,10"
				StrokeShape="Rectangle">
				<VerticalStackLayout Spacing="0">
					<Grid ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="8" Padding="0,0,0,6">
						<Border Grid.Column="0" AutomationId="OriginalTimetable.V1.Compact.FlyoutToggle" WidthRequest="40" HeightRequest="40" Padding="0" StrokeThickness="0" BackgroundColor="Transparent" VerticalOptions="Center">
							<Border.GestureRecognizers><TapGestureRecognizer Tapped="OnFlyoutToggleTapped"/></Border.GestureRecognizers>
							<Label Text="&#xE5D2;" FontFamily="MaterialIconsRegular" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
						</Border>
						<Label Grid.Column="1" AutomationId="OriginalTimetable.V1.Compact.Header.Depot" Text="{Binding DepotName, Source={x:Reference Self}}" FontSize="14" VerticalOptions="Center" LineBreakMode="TailTruncation" TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
						<HorizontalStackLayout Grid.Column="2" Spacing="2" VerticalOptions="Center" IsVisible="{Binding HasMultipleTrains, Source={x:Reference Self}}">
							<Border AutomationId="OriginalTimetable.V1.Compact.Header.PrevTrain" Padding="4,0" StrokeThickness="0" BackgroundColor="Transparent">
								<Border.GestureRecognizers><TapGestureRecognizer Tapped="OnPrevTrainTapped"/></Border.GestureRecognizers>
								<Label Text="&#xE5CB;" FontFamily="MaterialIconsRegular" FontSize="18" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
							</Border>
							<Border Padding="6,2" StrokeThickness="1" Stroke="{StaticResource OT_Rule}" Background="{StaticResource OT_BgSoft}" StrokeShape="RoundRectangle 99" VerticalOptions="Center">
								<HorizontalStackLayout Spacing="4" VerticalOptions="Center" BindableLayout.ItemsSource="{Binding PagerDots, Source={x:Reference Self}}">
									<BindableLayout.ItemTemplate>
										<DataTemplate>
											<Border HeightRequest="6" WidthRequest="6" StrokeThickness="0" Background="{StaticResource OT_RuleStrong}" StrokeShape="RoundRectangle 3" VerticalOptions="Center">
												<Border.Triggers>
													<DataTrigger TargetType="Border" Binding="{Binding}" Value="True">
														<Setter Property="WidthRequest" Value="18"/>
														<Setter Property="Background" Value="{StaticResource OT_Accent}"/>
													</DataTrigger>
												</Border.Triggers>
											</Border>
										</DataTemplate>
									</BindableLayout.ItemTemplate>
								</HorizontalStackLayout>
							</Border>
							<Border AutomationId="OriginalTimetable.V1.Compact.Header.NextTrain" Padding="4,0" StrokeThickness="0" BackgroundColor="Transparent">
								<Border.GestureRecognizers><TapGestureRecognizer Tapped="OnNextTrainTapped"/></Border.GestureRecognizers>
								<Label Text="&#xE5CC;" FontFamily="MaterialIconsRegular" FontSize="18" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
							</Border>
						</HorizontalStackLayout>
						<Label Grid.Column="3" AutomationId="OriginalTimetable.V1.Compact.Header.RouteName" Text="{Binding RouteNameText, Source={x:Reference Self}}" FontSize="15" FontAttributes="Bold" HorizontalOptions="End" VerticalOptions="Center" LineBreakMode="TailTruncation" TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
					</Grid>
					<BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource OT_Rule_Light}, Dark={StaticResource OT_Rule_Dark}}"/>
					<Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12" Padding="0,10,0,12">
						<Border Grid.Column="0" AutomationId="OriginalTimetable.V1.Compact.Header.TypeChip" Background="{StaticResource OT_Accent}" Padding="8,3" StrokeThickness="0" StrokeShape="RoundRectangle 4" IsVisible="{Binding HasHeaderType, Source={x:Reference Self}}" VerticalOptions="Center">
							<Label Text="{Binding HeaderTypeText, Source={x:Reference Self}}" FontSize="14" FontAttributes="Bold" LineBreakMode="NoWrap" TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"/>
						</Border>
						<Label Grid.Column="1" AutomationId="OriginalTimetable.V1.Compact.Header.TrainNumber" Text="{Binding HeaderTrainNumberText, Source={x:Reference Self}}" FontSize="28" FontAttributes="Bold" FontFamily="Menlo" LineBreakMode="NoWrap" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
						<VerticalStackLayout Grid.Column="2" Spacing="0" VerticalOptions="Center">
							<Label Text="両数" FontSize="11" HorizontalOptions="End" TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
							<Label AutomationId="OriginalTimetable.V1.Compact.Header.CarCount" Text="{Binding HeaderCarCountText, Source={x:Reference Self}}" FontSize="15" FontAttributes="Bold" HorizontalOptions="End" TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
						</VerticalStackLayout>
						<VerticalStackLayout Grid.Column="3" Spacing="0" VerticalOptions="Center">
							<Label Text="最高速度" FontSize="11" HorizontalOptions="End" TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
							<Label AutomationId="OriginalTimetable.V1.Compact.Header.MaxSpeed" Text="{Binding HeaderMaxSpeedText, Source={x:Reference Self}}" FontSize="15" FontAttributes="Bold" FontFamily="Menlo" HorizontalOptions="End" TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
						</VerticalStackLayout>
					</Grid>
					<BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource OT_Rule_Light}, Dark={StaticResource OT_Rule_Dark}}"/>
					<Grid ColumnDefinitions="Auto,*,Auto" Padding="0,6,0,0">
						<VerticalStackLayout Grid.Column="0" Spacing="0">
							<Label Text="現在時刻" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
							<Label AutomationId="OriginalTimetable.V1.Compact.Header.Clock" Text="{Binding CurrentTimeText, Source={x:Reference Self}}" FontSize="24" FontAttributes="Bold" FontFamily="Menlo" TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
						</VerticalStackLayout>
						<Label Grid.Column="2" AutomationId="OriginalTimetable.V1.Compact.Header.OriginDest" Text="{Binding OriginDestText, Source={x:Reference Self}}" FontSize="12" VerticalOptions="End" HorizontalOptions="End" LineBreakMode="TailTruncation" TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
					</Grid>
				</VerticalStackLayout>
			</Border>
			<!-- Empty-state when ActiveTrain is null -->
			<Label
				Grid.Row="1"
				AutomationId="OriginalTimetable.V1.Compact.EmptyState"
				IsVisible="{Binding HasNoActiveTrain, Source={x:Reference Self}}"
				Text="列車を選択してください"
				FontSize="14"
				HorizontalOptions="Center"
				VerticalOptions="Center"
				TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>

			<!-- Row list - BindableLayout host (replaces CollectionView) -->
			<ScrollView
				x:Name="CompactScroll"
				Grid.Row="1"
				AutomationId="OriginalTimetable.V1.Compact.RowsList"
				IsVisible="{Binding HasActiveTrain, Source={x:Reference Self}}">
				<VerticalStackLayout
					x:Name="CompactRowsHost"
					Spacing="0"
					BindableLayout.ItemsSource="{Binding Items, Source={x:Reference Self}}">
					<BindableLayout.ItemTemplate>
						<DataTemplate>
							<local:V1RowCompact/>
						</DataTemplate>
					</BindableLayout.ItemTemplate>
				</VerticalStackLayout>
			</ScrollView>
		</Grid>

		<!-- Memo bottom-sheet overlay (Phase 2) - unchanged shape. -->
		<Grid
			x:Name="MemoSheetOverlay"
			AutomationId="OriginalTimetable.V1.MemoSheet"
			IsVisible="False"
			BackgroundColor="#80000000"
			InputTransparent="False">
			<Grid.GestureRecognizers>
				<TapGestureRecognizer Tapped="OnMemoSheetScrimTapped"/>
			</Grid.GestureRecognizers>
			<Border
				AutomationId="OriginalTimetable.V1.MemoSheet.Scrim"
				VerticalOptions="End"
				StrokeShape="RoundRectangle 16,16,0,0"
				Background="{StaticResource OT_Bg}"
				Padding="20,24"
				StrokeThickness="0">
				<Border.GestureRecognizers>
					<TapGestureRecognizer Tapped="OnMemoSheetBodyTapped"/>
				</Border.GestureRecognizers>
				<VerticalStackLayout Spacing="12">
					<Label
						Text="メモ"
						FontSize="16"
						FontAttributes="Bold"
						TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
					<Editor
						x:Name="MemoEditor"
						AutomationId="OriginalTimetable.V1.MemoSheet.Editor"
						AutoSize="TextChanges"
						MinimumHeightRequest="120"
						Placeholder="メモを入力..."/>
					<HorizontalStackLayout Spacing="8" HorizontalOptions="End">
						<Button
							AutomationId="OriginalTimetable.V1.MemoSheet.Delete"
							Text="削除"
							Clicked="OnMemoDeleteClicked"
							BackgroundColor="{AppThemeBinding Light={StaticResource OT_WarnBg_Light}, Dark={StaticResource OT_WarnBg_Dark}}"
							TextColor="{AppThemeBinding Light={StaticResource OT_WarnFg_Light}, Dark={StaticResource OT_WarnFg_Dark}}"/>
						<Button
							AutomationId="OriginalTimetable.V1.MemoSheet.Cancel"
							Text="キャンセル"
							Clicked="OnMemoCancelClicked"/>
						<Button
							AutomationId="OriginalTimetable.V1.MemoSheet.Save"
							Text="保存"
							Clicked="OnMemoSaveClicked"
							BackgroundColor="{AppThemeBinding Light={StaticResource OT_Accent_Light}, Dark={StaticResource OT_Accent_Dark}}"
							TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"/>
					</HorizontalStackLayout>
				</VerticalStackLayout>
			</Border>
		</Grid>
	</Grid>
</ContentPage>
