<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
	xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
	xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
	xmlns:local="clr-namespace:TRViS.OriginalTimetable"
	x:Class="TRViS.OriginalTimetable.OriginalTimetableV1Page"
	x:Name="Self"
	Title="ダイヤ表 (V1)"
	BackgroundColor="{AppThemeBinding Light={StaticResource OT_Bg_Light}, Dark={StaticResource OT_Bg_Dark}}">
	<CollectionView
		ItemsSource="{Binding Source={x:Reference Self}, Path=Rows}"
		SelectionMode="None">
		<CollectionView.ItemTemplate>
			<DataTemplate x:DataType="local:RowVM">
				<SwipeView>
					<SwipeView.RightItems>
						<SwipeItems Mode="Reveal">
							<SwipeItem Text="マーカー" BackgroundColor="{StaticResource OT_Accent_Light}"/>
							<SwipeItem Text="メモ" BackgroundColor="{StaticResource OT_MarkerCautionBg}"/>
							<SwipeItem Text="クリア" BackgroundColor="{StaticResource OT_AccentSoft_Light}"/>
						</SwipeItems>
					</SwipeView.RightItems>
					<Grid>
						<!-- Section break row -->
						<Border
							IsVisible="{Binding IsSectionBreak}"
							Padding="12,6"
							Background="{StaticResource OT_AccentSoft}"
							StrokeShape="RoundRectangle 6"
							Margin="8,4">
							<Label
								Text="{Binding Run}"
								FontAttributes="Bold"
								HorizontalOptions="Center"
								VerticalOptions="Center"
								TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
						</Border>
						<!-- Normal row -->
						<Grid
							IsVisible="{Binding IsNormalRow}"
							ColumnDefinitions="48,*,80,80,40"
							Padding="12,8"
							RowSpacing="0">
							<Label
								Grid.Column="0"
								Text="{Binding Run}"
								VerticalOptions="Center"
								TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
							<HorizontalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
								<Border
									Padding="4,1"
									StrokeShape="RoundRectangle 4"
									Background="{StaticResource OT_AccentSoft}"
									StrokeThickness="0">
									<Label Text="◆" FontSize="11"
										TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
								</Border>
								<Label
									Text="{Binding StationName}"
									VerticalOptions="Center"
									TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
							</HorizontalStackLayout>
							<Label
								Grid.Column="2"
								Text="{Binding Arrive}"
								VerticalOptions="Center"
								HorizontalOptions="End"
								TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
							<Label
								Grid.Column="3"
								Text="{Binding Depart}"
								VerticalOptions="Center"
								HorizontalOptions="End"
								TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
							<Label
								Grid.Column="4"
								Text="{Binding Track}"
								VerticalOptions="Center"
								HorizontalOptions="Center"
								TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
						</Grid>
					</Grid>
				</SwipeView>
			</DataTemplate>
		</CollectionView.ItemTemplate>
	</CollectionView>
</ContentPage>
