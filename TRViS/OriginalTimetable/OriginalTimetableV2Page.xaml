<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
	xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
	xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
	xmlns:local="clr-namespace:TRViS.OriginalTimetable"
	xmlns:controls="clr-namespace:TRViS.Controls"
	x:Class="TRViS.OriginalTimetable.OriginalTimetableV2Page"
	x:Name="Self"
	Title="ダイヤ表 (V2)"
	Shell.NavBarIsVisible="False"
	SizeChanged="OnRootSizeChanged"
	BackgroundColor="{AppThemeBinding Light={StaticResource OT_Bg_Light}, Dark={StaticResource OT_Bg_Dark}}">
	<!--
		BindableLayout-based refactor (Apple Swift ObservationTracking workaround,
		swiftlang#84228). V2's previous shape used a <CollectionView> with a
		<DataTemplate> containing SwipeView + HtmlAutoDetectLabel; on iOS
		simulators this trips the ObservationTracking._AccessList /
		_NativeDictionary.copy use-after-free during cell recycling. Mirrors the
		V1 fix (commit 682e2d4).

		Shape:
		  ContentPage.Content = Grid (RootGrid)
		    |
		    +- Grid (TabletGrid, >=600pt)
		    |    +- Border : sticky header (type / number / dest / car / max / tweaks gear)
		    |    +- Label  : empty-state
		    |    +- ScrollView (TabletScroll)
		    |         +- VerticalStackLayout (TabletRowsHost)
		    |              BindableLayout.ItemsSource  = Items
		    |              BindableLayout.ItemTemplate = DataTemplate(local:V2RowTablet)
		    |
		    +- Grid (CompactGrid, <600pt) — mirrors TabletGrid at smaller scale
		    |    +- ScrollView (CompactScroll)
		    |         +- VerticalStackLayout (CompactRowsHost)
		    |              BindableLayout.ItemsSource  = Items
		    |              BindableLayout.ItemTemplate = DataTemplate(local:V2RowCompact)
		    |
		    +- Grid (MemoSheetOverlay)   ← unchanged overlay
		    +- Grid (TweaksOverlay)      ← unchanged overlay
	-->
	<Grid x:Name="RootGrid" AutomationId="OriginalTimetable.V2.Root">

		<!-- ===== Tablet layout (>= 600pt) ===== -->
		<Grid
			x:Name="TabletGrid"
			AutomationId="OriginalTimetable.V2.TabletGrid"
			RowDefinitions="Auto,*"
			IsVisible="False">

			<!-- Sticky train-info header -->
			<Border
				Grid.Row="0"
				AutomationId="OriginalTimetable.V2.Header"
				Background="{StaticResource OT_Bg}"
				Stroke="{StaticResource OT_Rule}"
				StrokeThickness="0,0,0,1"
				Padding="14,10"
				StrokeShape="Rectangle">
				<Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto" ColumnSpacing="12">
					<Border
						Grid.Column="0"
						Background="{StaticResource OT_Accent}"
						Padding="6,2"
						StrokeThickness="0"
						StrokeShape="RoundRectangle 4"
						IsVisible="{Binding HasHeaderType, Source={x:Reference Self}}"
						VerticalOptions="Center">
						<Label
							Text="{Binding HeaderTypeText, Source={x:Reference Self}}"
							FontSize="13"
							FontAttributes="Bold"
							TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"/>
					</Border>
					<Label
						Grid.Column="1"
						Text="{Binding HeaderTrainNumberText, Source={x:Reference Self}}"
						FontSize="22"
						FontAttributes="Bold"
						FontFamily="Menlo"
						VerticalOptions="Center"
						TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
					<Label
						Grid.Column="2"
						Text="{Binding HeaderDestinationText, Source={x:Reference Self}}"
						FontSize="14"
						VerticalOptions="Center"
						LineBreakMode="TailTruncation"
						TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
					<VerticalStackLayout Grid.Column="3" VerticalOptions="Center" HorizontalOptions="End">
						<Label
							Text="{Binding HeaderCarCountText, Source={x:Reference Self}}"
							FontSize="12"
							HorizontalOptions="End"
							TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
						<Label
							Text="{Binding HeaderMaxSpeedText, Source={x:Reference Self}}"
							FontSize="12"
							HorizontalOptions="End"
							TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
					</VerticalStackLayout>
					<!-- Tweaks panel toggle (Phase 3). Gear icon opens TweaksOverlay -->
					<Border
						Grid.Column="4"
						AutomationId="OriginalTimetable.V2.TweaksButton"
						Padding="6"
						StrokeThickness="0"
						BackgroundColor="Transparent"
						VerticalOptions="Center">
						<Border.GestureRecognizers>
							<TapGestureRecognizer Tapped="OnTweaksButtonTapped"/>
						</Border.GestureRecognizers>
						<Label
							Text="&#xE8B8;"
							FontFamily="MaterialIconsRegular"
							FontSize="22"
							TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
					</Border>
				</Grid>
			</Border>

			<!-- Empty-state when ActiveTrain is null -->
			<Label
				Grid.Row="1"
				AutomationId="OriginalTimetable.V2.EmptyState"
				IsVisible="{Binding HasNoActiveTrain, Source={x:Reference Self}}"
				Text="列車を選択してください"
				FontSize="16"
				HorizontalOptions="Center"
				VerticalOptions="Center"
				TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>

			<!-- Row list — BindableLayout host (replaces CollectionView) -->
			<ScrollView
				x:Name="TabletScroll"
				Grid.Row="1"
				AutomationId="OriginalTimetable.V2.RowsList"
				IsVisible="{Binding HasActiveTrain, Source={x:Reference Self}}">
				<VerticalStackLayout
					x:Name="TabletRowsHost"
					Spacing="0"
					BindableLayout.ItemsSource="{Binding Items, Source={x:Reference Self}}">
					<BindableLayout.ItemTemplate>
						<DataTemplate>
							<local:V2RowTablet/>
						</DataTemplate>
					</BindableLayout.ItemTemplate>
				</VerticalStackLayout>
			</ScrollView>
		</Grid>

		<!-- ===== Compact layout (< 600pt) ===== -->
		<Grid
			x:Name="CompactGrid"
			AutomationId="OriginalTimetable.V2.CompactGrid"
			RowDefinitions="Auto,*"
			IsVisible="False">

			<!-- Sticky train-info header (compact) -->
			<Border
				Grid.Row="0"
				AutomationId="OriginalTimetable.V2.Compact.Header"
				Background="{StaticResource OT_Bg}"
				Stroke="{StaticResource OT_Rule}"
				StrokeThickness="0,0,0,1"
				Padding="12,8"
				StrokeShape="Rectangle">
				<Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="8">
					<Border
						Grid.Column="0"
						Background="{StaticResource OT_Accent}"
						Padding="5,1"
						StrokeThickness="0"
						StrokeShape="RoundRectangle 4"
						IsVisible="{Binding HasHeaderType, Source={x:Reference Self}}"
						VerticalOptions="Center">
						<Label
							Text="{Binding HeaderTypeText, Source={x:Reference Self}}"
							FontSize="11"
							FontAttributes="Bold"
							TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"/>
					</Border>
					<Label
						Grid.Column="1"
						Text="{Binding HeaderTrainNumberText, Source={x:Reference Self}}"
						FontSize="17"
						FontAttributes="Bold"
						FontFamily="Menlo"
						VerticalOptions="Center"
						TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
					<Label
						Grid.Column="2"
						Text="{Binding HeaderDestinationText, Source={x:Reference Self}}"
						FontSize="12"
						VerticalOptions="Center"
						LineBreakMode="TailTruncation"
						TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
					<!-- Tweaks panel toggle (compact). Same handler as tablet gear. -->
					<Border
						Grid.Column="3"
						Padding="6"
						StrokeThickness="0"
						BackgroundColor="Transparent"
						VerticalOptions="Center">
						<Border.GestureRecognizers>
							<TapGestureRecognizer Tapped="OnTweaksButtonTapped"/>
						</Border.GestureRecognizers>
						<Label
							Text="&#xE8B8;"
							FontFamily="MaterialIconsRegular"
							FontSize="20"
							TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
					</Border>
				</Grid>
			</Border>

			<!-- Empty-state -->
			<Label
				Grid.Row="1"
				AutomationId="OriginalTimetable.V2.Compact.EmptyState"
				IsVisible="{Binding HasNoActiveTrain, Source={x:Reference Self}}"
				Text="列車を選択してください"
				FontSize="14"
				HorizontalOptions="Center"
				VerticalOptions="Center"
				TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>

			<!-- Row list (compact) — BindableLayout host -->
			<ScrollView
				x:Name="CompactScroll"
				Grid.Row="1"
				AutomationId="OriginalTimetable.V2.Compact.RowsList"
				IsVisible="{Binding HasActiveTrain, Source={x:Reference Self}}">
				<VerticalStackLayout
					x:Name="CompactRowsHost"
					Spacing="0"
					BindableLayout.ItemsSource="{Binding Items, Source={x:Reference Self}}">
					<BindableLayout.ItemTemplate>
						<DataTemplate>
							<local:V2RowCompact/>
						</DataTemplate>
					</BindableLayout.ItemTemplate>
				</VerticalStackLayout>
			</ScrollView>
		</Grid>

		<!-- Phase 2 — Memo bottom-sheet overlay. Sibling of TabletGrid /
		     CompactGrid so it overlays both layouts. IsVisible toggles open. -->
		<Grid
			x:Name="MemoSheetOverlay"
			AutomationId="OriginalTimetable.V2.MemoSheet"
			IsVisible="False"
			BackgroundColor="#80000000"
			InputTransparent="False">
			<Grid.GestureRecognizers>
				<TapGestureRecognizer Tapped="OnMemoSheetScrimTapped"/>
			</Grid.GestureRecognizers>
			<Border
				AutomationId="OriginalTimetable.V2.MemoSheet.Scrim"
				VerticalOptions="End"
				StrokeShape="RoundRectangle 16,16,0,0"
				Background="{StaticResource OT_Bg}"
				Padding="20,24"
				StrokeThickness="0">
				<Border.GestureRecognizers>
					<TapGestureRecognizer Tapped="OnMemoSheetBodyTapped"/>
				</Border.GestureRecognizers>
				<VerticalStackLayout Spacing="12">
					<Label
						Text="メモ"
						FontSize="16"
						FontAttributes="Bold"
						TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
					<Editor
						x:Name="MemoEditor"
						AutomationId="OriginalTimetable.V2.MemoSheet.Editor"
						AutoSize="TextChanges"
						MinimumHeightRequest="120"
						Placeholder="メモを入力..."/>
					<HorizontalStackLayout Spacing="8" HorizontalOptions="End">
						<Button
							AutomationId="OriginalTimetable.V2.MemoSheet.Delete"
							Text="削除"
							Clicked="OnMemoDeleteClicked"
							BackgroundColor="{AppThemeBinding Light={StaticResource OT_WarnBg_Light}, Dark={StaticResource OT_WarnBg_Dark}}"
							TextColor="{AppThemeBinding Light={StaticResource OT_WarnFg_Light}, Dark={StaticResource OT_WarnFg_Dark}}"/>
						<Button
							AutomationId="OriginalTimetable.V2.MemoSheet.Cancel"
							Text="キャンセル"
							Clicked="OnMemoCancelClicked"/>
						<Button
							AutomationId="OriginalTimetable.V2.MemoSheet.Save"
							Text="保存"
							Clicked="OnMemoSaveClicked"
							BackgroundColor="{AppThemeBinding Light={StaticResource OT_Accent_Light}, Dark={StaticResource OT_Accent_Dark}}"
							TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"/>
					</HorizontalStackLayout>
				</VerticalStackLayout>
			</Border>
		</Grid>

		<!-- Phase 3 — Tweaks panel overlay. -->
		<Grid
			x:Name="TweaksOverlay"
			AutomationId="OriginalTimetable.V2.Tweaks.Overlay"
			IsVisible="False"
			BackgroundColor="#80000000"
			InputTransparent="False">
			<Grid.GestureRecognizers>
				<TapGestureRecognizer Tapped="OnTweaksScrimTapped"/>
			</Grid.GestureRecognizers>
			<Border
				AutomationId="OriginalTimetable.V2.Tweaks.Scrim"
				HorizontalOptions="End"
				VerticalOptions="Start"
				Margin="0,60,16,0"
				StrokeShape="RoundRectangle 12"
				Background="{StaticResource OT_Bg}"
				Stroke="{StaticResource OT_Rule}"
				StrokeThickness="1"
				Padding="14,12"
				WidthRequest="240">
				<Border.GestureRecognizers>
					<TapGestureRecognizer Tapped="OnTweaksBodyTapped"/>
				</Border.GestureRecognizers>
				<VerticalStackLayout Spacing="14">
					<Label
						AutomationId="OriginalTimetable.V2.Tweaks.Title"
						Text="表示設定"
						FontSize="13"
						FontAttributes="Bold"
						TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>

					<!-- ShowPasses toggle -->
					<Grid ColumnDefinitions="*,Auto">
						<Label
							Grid.Column="0"
							Text="通過駅を表示"
							FontSize="13"
							VerticalOptions="Center"
							TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
						<Switch
							Grid.Column="1"
							AutomationId="OriginalTimetable.V2.Tweaks.ShowPasses"
							IsToggled="{Binding ShowPasses, Mode=TwoWay}"/>
					</Grid>

					<!-- Density tri-state segmented -->
					<VerticalStackLayout Spacing="4">
						<Label
							Text="行間"
							FontSize="12"
							TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
						<HorizontalStackLayout Spacing="6">
							<Border
								x:Name="DensityCompact"
								AutomationId="OriginalTimetable.V2.Tweaks.Density.Compact"
								StrokeShape="RoundRectangle 6"
								StrokeThickness="0"
								Padding="10,4"
								Background="{StaticResource OT_BgSoft}">
								<Border.GestureRecognizers>
									<TapGestureRecognizer Tapped="OnDensityCompactTapped"/>
								</Border.GestureRecognizers>
								<Label
									x:Name="DensityCompactLabel"
									Text="狭"
									FontSize="12"
									TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
							</Border>
							<Border
								x:Name="DensityComfortable"
								AutomationId="OriginalTimetable.V2.Tweaks.Density.Comfortable"
								StrokeShape="RoundRectangle 6"
								StrokeThickness="0"
								Padding="10,4"
								Background="{StaticResource OT_BgSoft}">
								<Border.GestureRecognizers>
									<TapGestureRecognizer Tapped="OnDensityComfortableTapped"/>
								</Border.GestureRecognizers>
								<Label
									x:Name="DensityComfortableLabel"
									Text="標準"
									FontSize="12"
									TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
							</Border>
							<Border
								x:Name="DensitySpacious"
								AutomationId="OriginalTimetable.V2.Tweaks.Density.Spacious"
								StrokeShape="RoundRectangle 6"
								StrokeThickness="0"
								Padding="10,4"
								Background="{StaticResource OT_BgSoft}">
								<Border.GestureRecognizers>
									<TapGestureRecognizer Tapped="OnDensitySpaciousTapped"/>
								</Border.GestureRecognizers>
								<Label
									x:Name="DensitySpaciousLabel"
									Text="広"
									FontSize="12"
									TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
							</Border>
						</HorizontalStackLayout>
					</VerticalStackLayout>
				</VerticalStackLayout>
			</Border>
		</Grid>
	</Grid>
</ContentPage>
