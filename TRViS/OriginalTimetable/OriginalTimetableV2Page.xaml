<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
	xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
	xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
	xmlns:local="clr-namespace:TRViS.OriginalTimetable"
	xmlns:controls="clr-namespace:TRViS.Controls"
	x:Class="TRViS.OriginalTimetable.OriginalTimetableV2Page"
	x:Name="Self"
	Title="ダイヤ表 (V2)"
	SizeChanged="OnRootSizeChanged"
	BackgroundColor="{AppThemeBinding Light={StaticResource OT_Bg_Light}, Dark={StaticResource OT_Bg_Dark}}">
	<!--
		BindableLayout-based refactor (Apple Swift ObservationTracking workaround,
		swiftlang#84228). V2's previous shape used a <CollectionView> with a
		<DataTemplate> containing SwipeView + HtmlAutoDetectLabel; on iOS
		simulators this trips the ObservationTracking._AccessList /
		_NativeDictionary.copy use-after-free during cell recycling. Mirrors the
		V1 fix (commit 682e2d4).

		Shape:
		  ContentPage.Content = Grid (RootGrid)
		    |
		    +- Grid (TabletGrid, >=600pt)
		    |    +- Border : sticky header (type / number / dest / car / max)
		    |    +- Label  : empty-state
		    |    +- ScrollView (TabletScroll)
		    |         +- VerticalStackLayout (TabletRowsHost)
		    |              BindableLayout.ItemsSource  = Items
		    |              BindableLayout.ItemTemplate = DataTemplate(local:V2RowTablet)
		    |
		    +- Grid (CompactGrid, <600pt) — mirrors TabletGrid at smaller scale
		    |    +- ScrollView (CompactScroll)
		    |         +- VerticalStackLayout (CompactRowsHost)
		    |              BindableLayout.ItemsSource  = Items
		    |              BindableLayout.ItemTemplate = DataTemplate(local:V2RowCompact)
		    |
		    +- Grid (MemoSheetOverlay)   ← unchanged overlay
	-->
	<Grid x:Name="RootGrid" AutomationId="OriginalTimetable.V2.Root">

		<!-- ===== Tablet layout (>= 600pt) ===== -->
		<Grid
			x:Name="TabletGrid"
			AutomationId="OriginalTimetable.V2.TabletGrid"
			RowDefinitions="Auto,*"
			IsVisible="False">

			<!-- Sticky train-info header (2 sections, mirrors design v2.jsx) -->
			<Border
				Grid.Row="0"
				AutomationId="OriginalTimetable.V2.Header"
				Background="{StaticResource OT_Bg}"
				Stroke="{StaticResource OT_Rule}"
				StrokeThickness="0,0,0,1"
				Padding="14,10"
				StrokeShape="Rectangle">
				<VerticalStackLayout Spacing="0">
					<Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="4" Padding="0,0,0,6">
						<Border Grid.Column="0" AutomationId="OriginalTimetable.V2.FlyoutToggle" WidthRequest="44" HeightRequest="44" Padding="0" StrokeThickness="0" BackgroundColor="Transparent" VerticalOptions="Center">
							<Border.GestureRecognizers><TapGestureRecognizer Tapped="OnFlyoutToggleTapped"/></Border.GestureRecognizers>
							<Label Text="&#xE5D2;" FontFamily="MaterialIconsRegular" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
						</Border>
						<Grid Grid.Column="1" ColumnDefinitions="*,Auto,*" ColumnSpacing="8" VerticalOptions="Center">
							<Label Grid.Column="0" AutomationId="OriginalTimetable.V2.Header.Brand" Text="{Binding BrandText, Source={x:Reference Self}}" FontSize="14" VerticalOptions="Center" LineBreakMode="TailTruncation" TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
							<HorizontalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center" HorizontalOptions="Center" IsVisible="{Binding HasMultipleTrains, Source={x:Reference Self}}">
								<Border AutomationId="OriginalTimetable.V2.Header.PrevTrain" Padding="4,0" StrokeThickness="0" BackgroundColor="Transparent">
									<Border.GestureRecognizers><TapGestureRecognizer Tapped="OnPrevTrainTapped"/></Border.GestureRecognizers>
									<Label Text="&#xE5CB;" FontFamily="MaterialIconsRegular" FontSize="18" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
								</Border>
								<Border Padding="6,2" StrokeThickness="1" Stroke="{StaticResource OT_Rule}" Background="{StaticResource OT_BgSoft}" StrokeShape="RoundRectangle 99" VerticalOptions="Center">
									<HorizontalStackLayout Spacing="4" VerticalOptions="Center" BindableLayout.ItemsSource="{Binding PagerDots, Source={x:Reference Self}}">
										<BindableLayout.ItemTemplate>
											<DataTemplate>
												<Border HeightRequest="6" WidthRequest="6" StrokeThickness="0" Background="{StaticResource OT_RuleStrong}" StrokeShape="RoundRectangle 3" VerticalOptions="Center">
													<Border.Triggers>
														<DataTrigger TargetType="Border" Binding="{Binding}" Value="True">
															<Setter Property="WidthRequest" Value="18"/>
															<Setter Property="Background" Value="{StaticResource OT_Accent}"/>
														</DataTrigger>
													</Border.Triggers>
												</Border>
											</DataTemplate>
										</BindableLayout.ItemTemplate>
									</HorizontalStackLayout>
								</Border>
								<Border AutomationId="OriginalTimetable.V2.Header.NextTrain" Padding="4,0" StrokeThickness="0" BackgroundColor="Transparent">
									<Border.GestureRecognizers><TapGestureRecognizer Tapped="OnNextTrainTapped"/></Border.GestureRecognizers>
									<Label Text="&#xE5CC;" FontFamily="MaterialIconsRegular" FontSize="18" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
								</Border>
							</HorizontalStackLayout>
							<Label Grid.Column="2" AutomationId="OriginalTimetable.V2.Header.WorkDate" Text="{Binding WorkDateText, Source={x:Reference Self}}" FontSize="14" HorizontalOptions="End" VerticalOptions="Center" LineBreakMode="TailTruncation" TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
						</Grid>
					</Grid>
					<BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource OT_Rule_Light}, Dark={StaticResource OT_Rule_Dark}}"/>
					<Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Padding="0,14,0,0">
						<Border Grid.Column="0" AutomationId="OriginalTimetable.V2.Header.TypeChip" Background="{StaticResource OT_Accent}" Padding="12,6" StrokeThickness="0" StrokeShape="RoundRectangle 6" IsVisible="{Binding HasHeaderType, Source={x:Reference Self}}" VerticalOptions="Center">
							<Label Text="{Binding HeaderTypeText, Source={x:Reference Self}}" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"/>
						</Border>
						<VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
							<Label AutomationId="OriginalTimetable.V2.Header.TrainNumber" Text="{Binding HeaderTrainNumberText, Source={x:Reference Self}}" FontSize="40" FontAttributes="Bold" FontFamily="Menlo" LineBreakMode="NoWrap" TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
							<Label AutomationId="OriginalTimetable.V2.Header.Meta" Text="{Binding SummaryMetaText, Source={x:Reference Self}}" FontSize="14" LineBreakMode="TailTruncation" TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
						</VerticalStackLayout>
						<VerticalStackLayout Grid.Column="2" Spacing="0" VerticalOptions="Center" HorizontalOptions="End">
							<Label AutomationId="OriginalTimetable.V2.Header.Clock" Text="{Binding CurrentTimeText, Source={x:Reference Self}}" FontSize="26" FontAttributes="Bold" FontFamily="Menlo" HorizontalOptions="End" TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
							<Label Text="NOW" FontSize="13" CharacterSpacing="2" HorizontalOptions="End" TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
						</VerticalStackLayout>
					</Grid>
				</VerticalStackLayout>
			</Border>
			<!-- Empty-state when ActiveTrain is null -->
			<Label
				Grid.Row="1"
				AutomationId="OriginalTimetable.V2.EmptyState"
				IsVisible="{Binding HasNoActiveTrain, Source={x:Reference Self}}"
				Text="列車を選択してください"
				FontSize="16"
				HorizontalOptions="Center"
				VerticalOptions="Center"
				TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>

			<!-- Row list — BindableLayout host (replaces CollectionView) -->
			<ScrollView
				x:Name="TabletScroll"
				Grid.Row="1"
				AutomationId="OriginalTimetable.V2.RowsList"
				IsVisible="{Binding HasActiveTrain, Source={x:Reference Self}}">
				<VerticalStackLayout
					x:Name="TabletRowsHost"
					Spacing="0"
					BindableLayout.ItemsSource="{Binding Items, Source={x:Reference Self}}">
					<BindableLayout.ItemTemplate>
						<DataTemplate>
							<local:V2RowTablet/>
						</DataTemplate>
					</BindableLayout.ItemTemplate>
				</VerticalStackLayout>
			</ScrollView>
		</Grid>

		<!-- ===== Compact layout (< 600pt) ===== -->
		<Grid
			x:Name="CompactGrid"
			AutomationId="OriginalTimetable.V2.CompactGrid"
			RowDefinitions="Auto,*"
			IsVisible="False">

			<!-- Sticky train-info header (2 sections, mirrors design v2.jsx) -->
			<Border
				Grid.Row="0"
				AutomationId="OriginalTimetable.V2.Compact.Header"
				Background="{StaticResource OT_Bg}"
				Stroke="{StaticResource OT_Rule}"
				StrokeThickness="0,0,0,1"
				Padding="14,10"
				StrokeShape="Rectangle">
				<VerticalStackLayout Spacing="0">
					<Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="4" Padding="0,0,0,6">
						<Border Grid.Column="0" AutomationId="OriginalTimetable.V2.Compact.FlyoutToggle" WidthRequest="40" HeightRequest="40" Padding="0" StrokeThickness="0" BackgroundColor="Transparent" VerticalOptions="Center">
							<Border.GestureRecognizers><TapGestureRecognizer Tapped="OnFlyoutToggleTapped"/></Border.GestureRecognizers>
							<Label Text="&#xE5D2;" FontFamily="MaterialIconsRegular" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
						</Border>
						<Grid Grid.Column="1" ColumnDefinitions="*,Auto,*" ColumnSpacing="8" VerticalOptions="Center">
							<Label Grid.Column="0" AutomationId="OriginalTimetable.V2.Compact.Header.Brand" Text="{Binding BrandText, Source={x:Reference Self}}" FontSize="13" VerticalOptions="Center" LineBreakMode="TailTruncation" TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
							<HorizontalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center" HorizontalOptions="Center" IsVisible="{Binding HasMultipleTrains, Source={x:Reference Self}}">
								<Border AutomationId="OriginalTimetable.V2.Compact.Header.PrevTrain" Padding="4,0" StrokeThickness="0" BackgroundColor="Transparent">
									<Border.GestureRecognizers><TapGestureRecognizer Tapped="OnPrevTrainTapped"/></Border.GestureRecognizers>
									<Label Text="&#xE5CB;" FontFamily="MaterialIconsRegular" FontSize="16" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
								</Border>
								<Border Padding="6,2" StrokeThickness="1" Stroke="{StaticResource OT_Rule}" Background="{StaticResource OT_BgSoft}" StrokeShape="RoundRectangle 99" VerticalOptions="Center">
									<HorizontalStackLayout Spacing="4" VerticalOptions="Center" BindableLayout.ItemsSource="{Binding PagerDots, Source={x:Reference Self}}">
										<BindableLayout.ItemTemplate>
											<DataTemplate>
												<Border HeightRequest="6" WidthRequest="6" StrokeThickness="0" Background="{StaticResource OT_RuleStrong}" StrokeShape="RoundRectangle 3" VerticalOptions="Center">
													<Border.Triggers>
														<DataTrigger TargetType="Border" Binding="{Binding}" Value="True">
															<Setter Property="WidthRequest" Value="18"/>
															<Setter Property="Background" Value="{StaticResource OT_Accent}"/>
														</DataTrigger>
													</Border.Triggers>
												</Border>
											</DataTemplate>
										</BindableLayout.ItemTemplate>
									</HorizontalStackLayout>
								</Border>
								<Border AutomationId="OriginalTimetable.V2.Compact.Header.NextTrain" Padding="4,0" StrokeThickness="0" BackgroundColor="Transparent">
									<Border.GestureRecognizers><TapGestureRecognizer Tapped="OnNextTrainTapped"/></Border.GestureRecognizers>
									<Label Text="&#xE5CC;" FontFamily="MaterialIconsRegular" FontSize="16" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
								</Border>
							</HorizontalStackLayout>
							<Label Grid.Column="2" AutomationId="OriginalTimetable.V2.Compact.Header.WorkDate" Text="{Binding WorkDateText, Source={x:Reference Self}}" FontSize="13" HorizontalOptions="End" VerticalOptions="Center" LineBreakMode="TailTruncation" TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
						</Grid>
					</Grid>
					<BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource OT_Rule_Light}, Dark={StaticResource OT_Rule_Dark}}"/>
					<Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Padding="0,14,0,0">
						<Border Grid.Column="0" AutomationId="OriginalTimetable.V2.Compact.Header.TypeChip" Background="{StaticResource OT_Accent}" Padding="10,4" StrokeThickness="0" StrokeShape="RoundRectangle 6" IsVisible="{Binding HasHeaderType, Source={x:Reference Self}}" VerticalOptions="Center">
							<Label Text="{Binding HeaderTypeText, Source={x:Reference Self}}" FontSize="14" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"/>
						</Border>
						<VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
							<Label AutomationId="OriginalTimetable.V2.Compact.Header.TrainNumber" Text="{Binding HeaderTrainNumberText, Source={x:Reference Self}}" FontSize="30" FontAttributes="Bold" FontFamily="Menlo" LineBreakMode="NoWrap" TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
							<Label AutomationId="OriginalTimetable.V2.Compact.Header.Meta" Text="{Binding SummaryMetaText, Source={x:Reference Self}}" FontSize="12" LineBreakMode="TailTruncation" TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
						</VerticalStackLayout>
						<VerticalStackLayout Grid.Column="2" Spacing="0" VerticalOptions="Center" HorizontalOptions="End">
							<Label AutomationId="OriginalTimetable.V2.Compact.Header.Clock" Text="{Binding CurrentTimeText, Source={x:Reference Self}}" FontSize="20" FontAttributes="Bold" FontFamily="Menlo" HorizontalOptions="End" TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
							<Label Text="NOW" FontSize="11" CharacterSpacing="2" HorizontalOptions="End" TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
						</VerticalStackLayout>
					</Grid>
				</VerticalStackLayout>
			</Border>
			<!-- Empty-state -->
			<Label
				Grid.Row="1"
				AutomationId="OriginalTimetable.V2.Compact.EmptyState"
				IsVisible="{Binding HasNoActiveTrain, Source={x:Reference Self}}"
				Text="列車を選択してください"
				FontSize="14"
				HorizontalOptions="Center"
				VerticalOptions="Center"
				TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>

			<!-- Row list (compact) — BindableLayout host -->
			<ScrollView
				x:Name="CompactScroll"
				Grid.Row="1"
				AutomationId="OriginalTimetable.V2.Compact.RowsList"
				IsVisible="{Binding HasActiveTrain, Source={x:Reference Self}}">
				<VerticalStackLayout
					x:Name="CompactRowsHost"
					Spacing="0"
					BindableLayout.ItemsSource="{Binding Items, Source={x:Reference Self}}">
					<BindableLayout.ItemTemplate>
						<DataTemplate>
							<local:V2RowCompact/>
						</DataTemplate>
					</BindableLayout.ItemTemplate>
				</VerticalStackLayout>
			</ScrollView>
		</Grid>

		<!-- Phase 2 — Memo bottom-sheet overlay. Sibling of TabletGrid /
		     CompactGrid so it overlays both layouts. IsVisible toggles open. -->
		<Grid
			x:Name="MemoSheetOverlay"
			AutomationId="OriginalTimetable.V2.MemoSheet"
			IsVisible="False"
			BackgroundColor="#80000000"
			InputTransparent="False">
			<Grid.GestureRecognizers>
				<TapGestureRecognizer Tapped="OnMemoSheetScrimTapped"/>
			</Grid.GestureRecognizers>
			<Border
				AutomationId="OriginalTimetable.V2.MemoSheet.Scrim"
				VerticalOptions="End"
				StrokeShape="RoundRectangle 16,16,0,0"
				Background="{StaticResource OT_Bg}"
				Padding="20,24"
				StrokeThickness="0">
				<Border.GestureRecognizers>
					<TapGestureRecognizer Tapped="OnMemoSheetBodyTapped"/>
				</Border.GestureRecognizers>
				<VerticalStackLayout Spacing="12">
					<Label
						Text="メモ"
						FontSize="16"
						FontAttributes="Bold"
						TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
					<Editor
						x:Name="MemoEditor"
						AutomationId="OriginalTimetable.V2.MemoSheet.Editor"
						AutoSize="TextChanges"
						MinimumHeightRequest="120"
						Placeholder="メモを入力..."/>
					<HorizontalStackLayout Spacing="8" HorizontalOptions="End">
						<Button
							AutomationId="OriginalTimetable.V2.MemoSheet.Delete"
							Text="削除"
							Clicked="OnMemoDeleteClicked"
							BackgroundColor="{AppThemeBinding Light={StaticResource OT_WarnBg_Light}, Dark={StaticResource OT_WarnBg_Dark}}"
							TextColor="{AppThemeBinding Light={StaticResource OT_WarnFg_Light}, Dark={StaticResource OT_WarnFg_Dark}}"/>
						<Button
							AutomationId="OriginalTimetable.V2.MemoSheet.Cancel"
							Text="キャンセル"
							Clicked="OnMemoCancelClicked"/>
						<Button
							AutomationId="OriginalTimetable.V2.MemoSheet.Save"
							Text="保存"
							Clicked="OnMemoSaveClicked"
							BackgroundColor="{AppThemeBinding Light={StaticResource OT_Accent_Light}, Dark={StaticResource OT_Accent_Dark}}"
							TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"/>
					</HorizontalStackLayout>
				</VerticalStackLayout>
			</Border>
		</Grid>
	</Grid>
</ContentPage>
