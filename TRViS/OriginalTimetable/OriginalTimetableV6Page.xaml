<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
	xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
	xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
	xmlns:local="clr-namespace:TRViS.OriginalTimetable"
	xmlns:controls="clr-namespace:TRViS.Controls"
	x:Class="TRViS.OriginalTimetable.OriginalTimetableV6Page"
	x:Name="Self"
	Title="ダイヤ表 (V6)"
	Shell.NavBarIsVisible="False"
	SizeChanged="OnRootSizeChanged"
	BackgroundColor="{AppThemeBinding Light={StaticResource OT_Bg_Light}, Dark={StaticResource OT_Bg_Dark}}">
	<Grid x:Name="RootGrid" AutomationId="OriginalTimetable.V6.Root">

		<!-- Tablet layout (>= 600pt) -->
		<Grid
			x:Name="TabletGrid"
			AutomationId="OriginalTimetable.V6.TabletGrid"
			RowDefinitions="Auto,Auto,Auto,Auto,*"
			IsVisible="False">

			<!-- Row 0: Masthead -->
			<Border
				Grid.Row="0"
				AutomationId="OriginalTimetable.V6.Masthead"
				Padding="16,12"
				StrokeThickness="0,0,0,2"
				Stroke="{StaticResource OT_Fg}"
				Background="{StaticResource OT_Bg}"
				StrokeShape="Rectangle">
				<VerticalStackLayout Spacing="2">
					<Label
						Text="{Binding DepotName, Source={x:Reference Self}}"
						FontSize="11"
						FontAttributes="Bold"
						CharacterSpacing="2"
						TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
					<HorizontalStackLayout Spacing="10">
						<Label
							Text="{Binding RouteNameText, Source={x:Reference Self}}"
							FontSize="{Binding TabletRouteFontSize, Source={x:Reference Self}}"
							FontAttributes="Bold"
							TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
						<Label
							Text="{Binding WorkDateText, Source={x:Reference Self}}"
							FontSize="13"
							VerticalOptions="Center"
							TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
					</HorizontalStackLayout>
				</VerticalStackLayout>
			</Border>

			<!-- Row 1: Train stripe (full-bleed) -->
			<Border
				Grid.Row="1"
				AutomationId="OriginalTimetable.V6.TrainStripe"
				Padding="16,12"
				StrokeThickness="0"
				StrokeShape="Rectangle"
				Background="{StaticResource OT_Accent}">
				<Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto" ColumnSpacing="14">
					<Label
						Grid.Column="0"
						Text="{Binding TrainNumberText, Source={x:Reference Self}}"
						FontSize="{Binding TabletTrainNumberFontSize, Source={x:Reference Self}}"
						FontAttributes="Bold"
						FontFamily="Menlo"
						VerticalOptions="Center"
						TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"/>
					<VerticalStackLayout Grid.Column="2" Spacing="0" VerticalOptions="Center">
						<Label
							Text="CARS"
							FontSize="10"
							CharacterSpacing="2"
							TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"
							Opacity="0.7"/>
						<Label
							Text="{Binding CarCountText, Source={x:Reference Self}}"
							FontSize="16"
							FontAttributes="Bold"
							TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"/>
					</VerticalStackLayout>
					<VerticalStackLayout Grid.Column="3" Spacing="0" VerticalOptions="Center">
						<Label
							Text="MAX"
							FontSize="10"
							CharacterSpacing="2"
							TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"
							Opacity="0.7"/>
						<Label
							Text="{Binding MaxSpeedText, Source={x:Reference Self}}"
							FontSize="16"
							FontAttributes="Bold"
							TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"/>
					</VerticalStackLayout>
					<VerticalStackLayout Grid.Column="4" Spacing="0" VerticalOptions="Center">
						<Label
							Text="DEST"
							FontSize="10"
							CharacterSpacing="2"
							TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"
							Opacity="0.7"/>
						<Label
							Text="{Binding DestinationText, Source={x:Reference Self}}"
							FontSize="16"
							FontAttributes="Bold"
							TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"/>
					</VerticalStackLayout>
					<!-- Phase 3: gear button opens TweaksOverlay -->
					<Border
						Grid.Column="5"
						AutomationId="OriginalTimetable.V6.TweaksButton"
						Padding="6"
						StrokeThickness="0"
						BackgroundColor="Transparent"
						VerticalOptions="Center">
						<Border.GestureRecognizers>
							<TapGestureRecognizer Tapped="OnTweaksButtonTapped"/>
						</Border.GestureRecognizers>
						<Label
							Text="&#xE8B8;"
							FontFamily="MaterialIconsRegular"
							FontSize="22"
							TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"/>
					</Border>
				</Grid>
			</Border>

			<!-- Row 2: Past chips -->
			<Border
				Grid.Row="2"
				AutomationId="OriginalTimetable.V6.PastChips"
				Padding="16,8"
				StrokeThickness="0,0,0,1"
				Stroke="{StaticResource OT_Rule}"
				StrokeShape="Rectangle"
				Background="{StaticResource OT_Bg}">
				<ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
					<HorizontalStackLayout Spacing="6" VerticalOptions="Center">
						<Label
							Text="済"
							FontSize="11"
							VerticalOptions="Center"
							TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
						<Label
							Text="—"
							FontSize="11"
							VerticalOptions="Center"
							IsVisible="{Binding HasNoPastChips, Source={x:Reference Self}}"
							TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
						<BindableLayout.ItemsSource>
							<Binding Path="PastChips" Source="{x:Reference Self}"/>
						</BindableLayout.ItemsSource>
						<BindableLayout.ItemTemplate>
							<DataTemplate x:DataType="local:V6PastChipItem">
								<Border
									AutomationId="{Binding ChipAutomationId}"
									Padding="6,2"
									StrokeThickness="0"
									StrokeShape="RoundRectangle 10"
									Background="{StaticResource OT_BgSoft}"
									VerticalOptions="Center">
									<Border.GestureRecognizers>
										<TapGestureRecognizer Tapped="OnPastChipTapped"/>
									</Border.GestureRecognizers>
									<Label
										Text="{Binding StationName}"
										FontSize="{Binding TabletPastChipFontSize, Source={x:Reference Self}}"
										TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
								</Border>
							</DataTemplate>
						</BindableLayout.ItemTemplate>
					</HorizontalStackLayout>
				</ScrollView>
			</Border>

			<!-- Row 3: Current big block -->
			<SwipeView
				Grid.Row="3"
				AutomationId="OriginalTimetable.V6.CurrentBlock"
				IsVisible="{Binding HasCurrentStation, Source={x:Reference Self}}">
				<SwipeView.RightItems>
					<SwipeItems Mode="Reveal">
						<SwipeItem
							Text="マーカー"
							BackgroundColor="{AppThemeBinding Light={StaticResource OT_Accent_Light}, Dark={StaticResource OT_Accent_Dark}}"
							Command="{Binding OpenMarkerPopoverFromSwipeCommand, Source={x:Reference Self}}"
							CommandParameter="{Binding CurrentRowId, Source={x:Reference Self}}"/>
						<SwipeItem
							Text="メモ"
							BackgroundColor="{StaticResource OT_MarkerCautionBg}"
							Command="{Binding OpenMemoCommand, Source={x:Reference Self}}"
							CommandParameter="{Binding CurrentRowId, Source={x:Reference Self}}"/>
						<SwipeItem
							Text="クリア"
							BackgroundColor="{AppThemeBinding Light={StaticResource OT_AccentSoft_Light}, Dark={StaticResource OT_AccentSoft_Dark}}"
							Command="{Binding ClearMarkerCommand, Source={x:Reference Self}}"
							CommandParameter="{Binding CurrentRowId, Source={x:Reference Self}}"/>
					</SwipeItems>
				</SwipeView.RightItems>
				<Border
					Padding="24,20"
					StrokeThickness="0,1,0,1"
					Stroke="{StaticResource OT_Accent}"
					StrokeShape="Rectangle"
					Background="{StaticResource OT_AccentSoft}">
					<VerticalStackLayout Spacing="10">
						<HorizontalStackLayout Spacing="10">
							<Label
								Text="NOW APPROACHING"
								FontSize="11"
								FontAttributes="Bold"
								CharacterSpacing="3"
								VerticalOptions="Center"
								TextColor="{AppThemeBinding Light={StaticResource OT_AccentFgStrong_Light}, Dark={StaticResource OT_AccentFgStrong_Dark}}"/>
							<!-- Current marker badge (Phase 2). Tap → MarkerPopover anchored to badge -->
							<Border
								AutomationId="OriginalTimetable.V6.CurrentBlock.MarkerBadge"
								IsVisible="{Binding HasCurrentMarker, Source={x:Reference Self}}"
								Padding="6,1"
								StrokeThickness="0"
								StrokeShape="RoundRectangle 4"
								VerticalOptions="Center"
								Background="{StaticResource OT_Bg}">
								<Border.GestureRecognizers>
									<TapGestureRecognizer Tapped="OnCurrentMarkerBadgeTapped"/>
								</Border.GestureRecognizers>
								<Border.Triggers>
									<DataTrigger TargetType="Border" Binding="{Binding IsCurrentMarkerFlag, Source={x:Reference Self}}" Value="True">
										<Setter Property="Background" Value="{StaticResource OT_MarkerFlagBgBrush}"/>
									</DataTrigger>
									<DataTrigger TargetType="Border" Binding="{Binding IsCurrentMarkerCaution, Source={x:Reference Self}}" Value="True">
										<Setter Property="Background" Value="{StaticResource OT_MarkerCautionBgBrush}"/>
									</DataTrigger>
									<DataTrigger TargetType="Border" Binding="{Binding IsCurrentMarkerStar, Source={x:Reference Self}}" Value="True">
										<Setter Property="Background" Value="{StaticResource OT_MarkerStarBgBrush}"/>
									</DataTrigger>
								</Border.Triggers>
								<Label
									Text="{Binding CurrentMarkerText, Source={x:Reference Self}}"
									FontSize="11"
									FontAttributes="Bold"
									TextColor="{StaticResource OT_MarkerFlagFg}">
									<Label.Triggers>
										<DataTrigger TargetType="Label" Binding="{Binding IsCurrentMarkerCaution, Source={x:Reference Self}}" Value="True">
											<Setter Property="TextColor" Value="{StaticResource OT_MarkerCautionFg}"/>
										</DataTrigger>
										<DataTrigger TargetType="Label" Binding="{Binding IsCurrentMarkerStar, Source={x:Reference Self}}" Value="True">
											<Setter Property="TextColor" Value="{StaticResource OT_MarkerStarFg}"/>
										</DataTrigger>
									</Label.Triggers>
								</Label>
							</Border>
						</HorizontalStackLayout>
						<Label
							AutomationId="OriginalTimetable.V6.CurrentBlock.StationName"
							Text="{Binding CurrentStationName, Source={x:Reference Self}}"
							FontSize="{Binding TabletCurrentStationFontSize, Source={x:Reference Self}}"
							FontAttributes="Bold"
							TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
						<Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="18">
							<VerticalStackLayout Grid.Column="0" Spacing="2">
								<Label
									Text="着"
									FontSize="11"
									CharacterSpacing="2"
									TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
								<Label
									Text="{Binding CurrentStationArrive, Source={x:Reference Self}}"
									FontSize="{Binding TabletCurrentTimeFontSize, Source={x:Reference Self}}"
									FontAttributes="Bold"
									FontFamily="Menlo"
									TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
							</VerticalStackLayout>
							<VerticalStackLayout Grid.Column="1" Spacing="2">
								<Label
									Text="発"
									FontSize="11"
									CharacterSpacing="2"
									TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
								<Label
									Text="{Binding CurrentStationDepart, Source={x:Reference Self}}"
									FontSize="{Binding TabletCurrentTimeFontSize, Source={x:Reference Self}}"
									FontAttributes="Bold"
									FontFamily="Menlo"
									TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
							</VerticalStackLayout>
							<Border
								Grid.Column="3"
								IsVisible="{Binding HasCurrentStationTrack, Source={x:Reference Self}}"
								WidthRequest="64"
								HeightRequest="64"
								StrokeThickness="3"
								Stroke="{StaticResource OT_Fg}"
								StrokeShape="Rectangle"
								BackgroundColor="Transparent"
								VerticalOptions="End">
								<Label
									Text="{Binding CurrentStationTrack, Source={x:Reference Self}}"
									FontSize="32"
									FontAttributes="Bold"
									FontFamily="Menlo"
									HorizontalOptions="Center"
									VerticalOptions="Center"
									TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
							</Border>
						</Grid>
						<!-- Current note body (Phase 2). Read-only Remarks for current station.
						     Content (HtmlAutoDetectLabel) lazily constructed in
						     code-behind (EnsureCurrentNoteLabel) the first time
						     HasCurrentNote flips true — see XAML comment in V4Page
						     for the SwiftUI bug (swiftlang#84228) this avoids. -->
						<Border
							x:Name="CurrentNoteHost"
							AutomationId="OriginalTimetable.V6.CurrentBlock.NoteBody"
							IsVisible="{Binding HasCurrentNote, Source={x:Reference Self}}"
							Background="{AppThemeBinding Light={StaticResource OT_BgSoft_Light}, Dark={StaticResource OT_BgSoft_Dark}}"
							StrokeThickness="0"
							StrokeShape="RoundRectangle 6"
							Padding="10,6"/>
					</VerticalStackLayout>
				</Border>
			</SwipeView>

			<!-- Empty-state when ActiveTrain is null -->
			<Label
				Grid.Row="4"
				AutomationId="OriginalTimetable.V6.EmptyState"
				IsVisible="{Binding HasNoActiveTrain, Source={x:Reference Self}}"
				Text="列車を選択してください"
				FontSize="16"
				HorizontalOptions="Center"
				VerticalOptions="Center"
				TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>

			<!-- Row 4: Upcoming list (BindableLayout host — see V6Row.cs) -->
			<ScrollView
				x:Name="TabletScroll"
				Grid.Row="4"
				AutomationId="OriginalTimetable.V6.UpcomingList"
				IsVisible="{Binding HasActiveTrain, Source={x:Reference Self}}">
				<VerticalStackLayout
					x:Name="TabletRowsHost"
					Spacing="0"
					BindableLayout.ItemsSource="{Binding Items, Source={x:Reference Self}}">
					<BindableLayout.ItemTemplate>
						<DataTemplate>
							<local:V6RowTablet/>
						</DataTemplate>
					</BindableLayout.ItemTemplate>
				</VerticalStackLayout>
			</ScrollView>
		</Grid>

		<!-- Compact layout (< 600pt) — mirrors TabletGrid structure with smaller fonts. -->
		<Grid
			x:Name="CompactGrid"
			AutomationId="OriginalTimetable.V6.CompactGrid"
			RowDefinitions="Auto,Auto,Auto,Auto,*"
			IsVisible="False">

			<!-- Row 0: Masthead (compact) -->
			<Border
				Grid.Row="0"
				AutomationId="OriginalTimetable.V6.Compact.Masthead"
				Padding="12,8"
				StrokeThickness="0,0,0,2"
				Stroke="{StaticResource OT_Fg}"
				Background="{StaticResource OT_Bg}"
				StrokeShape="Rectangle">
				<VerticalStackLayout Spacing="1">
					<Label
						Text="{Binding DepotName, Source={x:Reference Self}}"
						FontSize="10"
						FontAttributes="Bold"
						CharacterSpacing="2"
						TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
					<HorizontalStackLayout Spacing="6">
						<Label
							Text="{Binding RouteNameText, Source={x:Reference Self}}"
							FontSize="{Binding CompactRouteFontSize, Source={x:Reference Self}}"
							FontAttributes="Bold"
							TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
						<Label
							Text="{Binding WorkDateText, Source={x:Reference Self}}"
							FontSize="11"
							VerticalOptions="Center"
							TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
					</HorizontalStackLayout>
				</VerticalStackLayout>
			</Border>

			<!-- Row 1: Train stripe (compact) -->
			<Border
				Grid.Row="1"
				AutomationId="OriginalTimetable.V6.Compact.TrainStripe"
				Padding="12,8"
				StrokeThickness="0"
				StrokeShape="Rectangle"
				Background="{StaticResource OT_Accent}">
				<Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
					<Label
						Grid.Column="0"
						Text="{Binding TrainNumberText, Source={x:Reference Self}}"
						FontSize="{Binding CompactTrainNumberFontSize, Source={x:Reference Self}}"
						FontAttributes="Bold"
						FontFamily="Menlo"
						VerticalOptions="Center"
						TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"/>
					<VerticalStackLayout Grid.Column="2" Spacing="0" VerticalOptions="Center">
						<Label
							Text="CARS"
							FontSize="9"
							CharacterSpacing="2"
							TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"
							Opacity="0.7"/>
						<Label
							Text="{Binding CarCountText, Source={x:Reference Self}}"
							FontSize="13"
							FontAttributes="Bold"
							TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"/>
					</VerticalStackLayout>
					<VerticalStackLayout Grid.Column="3" Spacing="0" VerticalOptions="Center">
						<Label
							Text="MAX"
							FontSize="9"
							CharacterSpacing="2"
							TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"
							Opacity="0.7"/>
						<Label
							Text="{Binding MaxSpeedText, Source={x:Reference Self}}"
							FontSize="13"
							FontAttributes="Bold"
							TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"/>
					</VerticalStackLayout>
					<VerticalStackLayout Grid.Column="4" Spacing="0" VerticalOptions="Center">
						<Label
							Text="DEST"
							FontSize="9"
							CharacterSpacing="2"
							TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"
							Opacity="0.7"/>
						<Label
							Text="{Binding DestinationText, Source={x:Reference Self}}"
							FontSize="13"
							FontAttributes="Bold"
							LineBreakMode="TailTruncation"
							TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"/>
					</VerticalStackLayout>
					<!-- Phase 3: gear button opens TweaksOverlay (compact) -->
					<Border
						Grid.Column="5"
						AutomationId="OriginalTimetable.V6.Compact.TweaksButton"
						Padding="4"
						StrokeThickness="0"
						BackgroundColor="Transparent"
						VerticalOptions="Center">
						<Border.GestureRecognizers>
							<TapGestureRecognizer Tapped="OnTweaksButtonTapped"/>
						</Border.GestureRecognizers>
						<Label
							Text="&#xE8B8;"
							FontFamily="MaterialIconsRegular"
							FontSize="18"
							TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"/>
					</Border>
				</Grid>
			</Border>

			<!-- Row 2: Past chips (compact) -->
			<Border
				Grid.Row="2"
				AutomationId="OriginalTimetable.V6.Compact.PastChips"
				Padding="12,6"
				StrokeThickness="0,0,0,1"
				Stroke="{StaticResource OT_Rule}"
				StrokeShape="Rectangle"
				Background="{StaticResource OT_Bg}">
				<ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
					<HorizontalStackLayout Spacing="4" VerticalOptions="Center">
						<Label
							Text="済"
							FontSize="10"
							VerticalOptions="Center"
							TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
						<Label
							Text="—"
							FontSize="10"
							VerticalOptions="Center"
							IsVisible="{Binding HasNoPastChips, Source={x:Reference Self}}"
							TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
						<BindableLayout.ItemsSource>
							<Binding Path="PastChips" Source="{x:Reference Self}"/>
						</BindableLayout.ItemsSource>
						<BindableLayout.ItemTemplate>
							<DataTemplate x:DataType="local:V6PastChipItem">
								<Border
									AutomationId="{Binding ChipAutomationId}"
									Padding="5,1"
									StrokeThickness="0"
									StrokeShape="RoundRectangle 8"
									Background="{StaticResource OT_BgSoft}"
									VerticalOptions="Center">
									<Border.GestureRecognizers>
										<TapGestureRecognizer Tapped="OnPastChipTapped"/>
									</Border.GestureRecognizers>
									<Label
										Text="{Binding StationName}"
										FontSize="{Binding CompactPastChipFontSize, Source={x:Reference Self}}"
										TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
								</Border>
							</DataTemplate>
						</BindableLayout.ItemTemplate>
					</HorizontalStackLayout>
				</ScrollView>
			</Border>

			<!-- Row 3: Current big block (compact) -->
			<SwipeView
				Grid.Row="3"
				AutomationId="OriginalTimetable.V6.Compact.CurrentBlock"
				IsVisible="{Binding HasCurrentStation, Source={x:Reference Self}}">
				<SwipeView.RightItems>
					<SwipeItems Mode="Reveal">
						<SwipeItem
							Text="マーカー"
							BackgroundColor="{AppThemeBinding Light={StaticResource OT_Accent_Light}, Dark={StaticResource OT_Accent_Dark}}"
							Command="{Binding OpenMarkerPopoverFromSwipeCommand, Source={x:Reference Self}}"
							CommandParameter="{Binding CurrentRowId, Source={x:Reference Self}}"/>
						<SwipeItem
							Text="メモ"
							BackgroundColor="{StaticResource OT_MarkerCautionBg}"
							Command="{Binding OpenMemoCommand, Source={x:Reference Self}}"
							CommandParameter="{Binding CurrentRowId, Source={x:Reference Self}}"/>
						<SwipeItem
							Text="クリア"
							BackgroundColor="{AppThemeBinding Light={StaticResource OT_AccentSoft_Light}, Dark={StaticResource OT_AccentSoft_Dark}}"
							Command="{Binding ClearMarkerCommand, Source={x:Reference Self}}"
							CommandParameter="{Binding CurrentRowId, Source={x:Reference Self}}"/>
					</SwipeItems>
				</SwipeView.RightItems>
				<Border
					Padding="14,14"
					StrokeThickness="0,1,0,1"
					Stroke="{StaticResource OT_Accent}"
					StrokeShape="Rectangle"
					Background="{StaticResource OT_AccentSoft}">
					<VerticalStackLayout Spacing="8">
						<HorizontalStackLayout Spacing="8">
							<Label
								Text="NOW APPROACHING"
								FontSize="10"
								FontAttributes="Bold"
								CharacterSpacing="3"
								VerticalOptions="Center"
								TextColor="{AppThemeBinding Light={StaticResource OT_AccentFgStrong_Light}, Dark={StaticResource OT_AccentFgStrong_Dark}}"/>
							<!-- Current marker badge (compact, Phase 2) -->
							<Border
								AutomationId="OriginalTimetable.V6.Compact.CurrentBlock.MarkerBadge"
								IsVisible="{Binding HasCurrentMarker, Source={x:Reference Self}}"
								Padding="5,1"
								StrokeThickness="0"
								StrokeShape="RoundRectangle 4"
								VerticalOptions="Center"
								Background="{StaticResource OT_Bg}">
								<Border.GestureRecognizers>
									<TapGestureRecognizer Tapped="OnCurrentMarkerBadgeTapped"/>
								</Border.GestureRecognizers>
								<Border.Triggers>
									<DataTrigger TargetType="Border" Binding="{Binding IsCurrentMarkerFlag, Source={x:Reference Self}}" Value="True">
										<Setter Property="Background" Value="{StaticResource OT_MarkerFlagBgBrush}"/>
									</DataTrigger>
									<DataTrigger TargetType="Border" Binding="{Binding IsCurrentMarkerCaution, Source={x:Reference Self}}" Value="True">
										<Setter Property="Background" Value="{StaticResource OT_MarkerCautionBgBrush}"/>
									</DataTrigger>
									<DataTrigger TargetType="Border" Binding="{Binding IsCurrentMarkerStar, Source={x:Reference Self}}" Value="True">
										<Setter Property="Background" Value="{StaticResource OT_MarkerStarBgBrush}"/>
									</DataTrigger>
								</Border.Triggers>
								<Label
									Text="{Binding CurrentMarkerText, Source={x:Reference Self}}"
									FontSize="10"
									FontAttributes="Bold"
									TextColor="{StaticResource OT_MarkerFlagFg}">
									<Label.Triggers>
										<DataTrigger TargetType="Label" Binding="{Binding IsCurrentMarkerCaution, Source={x:Reference Self}}" Value="True">
											<Setter Property="TextColor" Value="{StaticResource OT_MarkerCautionFg}"/>
										</DataTrigger>
										<DataTrigger TargetType="Label" Binding="{Binding IsCurrentMarkerStar, Source={x:Reference Self}}" Value="True">
											<Setter Property="TextColor" Value="{StaticResource OT_MarkerStarFg}"/>
										</DataTrigger>
									</Label.Triggers>
								</Label>
							</Border>
						</HorizontalStackLayout>
						<Label
							Text="{Binding CurrentStationName, Source={x:Reference Self}}"
							FontSize="{Binding CompactCurrentStationFontSize, Source={x:Reference Self}}"
							FontAttributes="Bold"
							TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
						<Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="14">
							<VerticalStackLayout Grid.Column="0" Spacing="2">
								<Label
									Text="着"
									FontSize="10"
									CharacterSpacing="2"
									TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
								<Label
									Text="{Binding CurrentStationArrive, Source={x:Reference Self}}"
									FontSize="{Binding CompactCurrentTimeFontSize, Source={x:Reference Self}}"
									FontAttributes="Bold"
									FontFamily="Menlo"
									TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
							</VerticalStackLayout>
							<VerticalStackLayout Grid.Column="1" Spacing="2">
								<Label
									Text="発"
									FontSize="10"
									CharacterSpacing="2"
									TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
								<Label
									Text="{Binding CurrentStationDepart, Source={x:Reference Self}}"
									FontSize="{Binding CompactCurrentTimeFontSize, Source={x:Reference Self}}"
									FontAttributes="Bold"
									FontFamily="Menlo"
									TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
							</VerticalStackLayout>
							<Border
								Grid.Column="3"
								IsVisible="{Binding HasCurrentStationTrack, Source={x:Reference Self}}"
								WidthRequest="48"
								HeightRequest="48"
								StrokeThickness="3"
								Stroke="{StaticResource OT_Fg}"
								StrokeShape="Rectangle"
								BackgroundColor="Transparent"
								VerticalOptions="End">
								<Label
									Text="{Binding CurrentStationTrack, Source={x:Reference Self}}"
									FontSize="24"
									FontAttributes="Bold"
									FontFamily="Menlo"
									HorizontalOptions="Center"
									VerticalOptions="Center"
									TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
							</Border>
						</Grid>
						<!-- Current note body (compact, Phase 2).
						     Lazy HAL construction — see CurrentNoteHost comment above. -->
						<Border
							x:Name="CompactCurrentNoteHost"
							AutomationId="OriginalTimetable.V6.Compact.CurrentBlock.NoteBody"
							IsVisible="{Binding HasCurrentNote, Source={x:Reference Self}}"
							Background="{AppThemeBinding Light={StaticResource OT_BgSoft_Light}, Dark={StaticResource OT_BgSoft_Dark}}"
							StrokeThickness="0"
							StrokeShape="RoundRectangle 6"
							Padding="8,5"/>
					</VerticalStackLayout>
				</Border>
			</SwipeView>

			<!-- Empty-state -->
			<Label
				Grid.Row="4"
				AutomationId="OriginalTimetable.V6.Compact.EmptyState"
				IsVisible="{Binding HasNoActiveTrain, Source={x:Reference Self}}"
				Text="列車を選択してください"
				FontSize="14"
				HorizontalOptions="Center"
				VerticalOptions="Center"
				TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>

			<!-- Row 4: Upcoming list (compact) — BindableLayout host -->
			<ScrollView
				x:Name="CompactScroll"
				Grid.Row="4"
				AutomationId="OriginalTimetable.V6.Compact.UpcomingList"
				IsVisible="{Binding HasActiveTrain, Source={x:Reference Self}}">
				<VerticalStackLayout
					x:Name="CompactRowsHost"
					Spacing="0"
					BindableLayout.ItemsSource="{Binding Items, Source={x:Reference Self}}">
					<BindableLayout.ItemTemplate>
						<DataTemplate>
							<local:V6RowCompact/>
						</DataTemplate>
					</BindableLayout.ItemTemplate>
				</VerticalStackLayout>
			</ScrollView>
		</Grid>

		<!-- Phase 2 — Memo bottom-sheet overlay (sibling of Tablet/Compact). -->
		<Grid
			x:Name="MemoSheetOverlay"
			AutomationId="OriginalTimetable.V6.MemoSheet"
			IsVisible="False"
			BackgroundColor="#80000000"
			InputTransparent="False">
			<Grid.GestureRecognizers>
				<TapGestureRecognizer Tapped="OnMemoSheetScrimTapped"/>
			</Grid.GestureRecognizers>
			<Border
				AutomationId="OriginalTimetable.V6.MemoSheet.Scrim"
				VerticalOptions="End"
				StrokeShape="RoundRectangle 16,16,0,0"
				Background="{StaticResource OT_Bg}"
				Padding="20,24"
				StrokeThickness="0">
				<Border.GestureRecognizers>
					<TapGestureRecognizer Tapped="OnMemoSheetBodyTapped"/>
				</Border.GestureRecognizers>
				<VerticalStackLayout Spacing="12">
					<Label
						Text="メモ"
						FontSize="16"
						FontAttributes="Bold"
						TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
					<Editor
						x:Name="MemoEditor"
						AutomationId="OriginalTimetable.V6.MemoSheet.Editor"
						AutoSize="TextChanges"
						MinimumHeightRequest="120"
						Placeholder="メモを入力..."/>
					<HorizontalStackLayout Spacing="8" HorizontalOptions="End">
						<Button
							AutomationId="OriginalTimetable.V6.MemoSheet.Delete"
							Text="削除"
							Clicked="OnMemoDeleteClicked"
							BackgroundColor="{AppThemeBinding Light={StaticResource OT_WarnBg_Light}, Dark={StaticResource OT_WarnBg_Dark}}"
							TextColor="{AppThemeBinding Light={StaticResource OT_WarnFg_Light}, Dark={StaticResource OT_WarnFg_Dark}}"/>
						<Button
							AutomationId="OriginalTimetable.V6.MemoSheet.Cancel"
							Text="キャンセル"
							Clicked="OnMemoCancelClicked"/>
						<Button
							AutomationId="OriginalTimetable.V6.MemoSheet.Save"
							Text="保存"
							Clicked="OnMemoSaveClicked"
							BackgroundColor="{AppThemeBinding Light={StaticResource OT_Accent_Light}, Dark={StaticResource OT_Accent_Dark}}"
							TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"/>
					</HorizontalStackLayout>
				</VerticalStackLayout>
			</Border>
		</Grid>

		<!-- Phase 3 — Tweaks panel overlay. -->
		<Grid
			x:Name="TweaksOverlay"
			AutomationId="OriginalTimetable.V6.Tweaks.Overlay"
			IsVisible="False"
			BackgroundColor="#80000000"
			InputTransparent="False">
			<Grid.GestureRecognizers>
				<TapGestureRecognizer Tapped="OnTweaksScrimTapped"/>
			</Grid.GestureRecognizers>
			<Border
				AutomationId="OriginalTimetable.V6.Tweaks.Scrim"
				HorizontalOptions="End"
				VerticalOptions="Start"
				Margin="0,60,16,0"
				StrokeShape="RoundRectangle 12"
				Background="{StaticResource OT_Bg}"
				Stroke="{StaticResource OT_Rule}"
				StrokeThickness="1"
				Padding="14,12"
				WidthRequest="240">
				<Border.GestureRecognizers>
					<TapGestureRecognizer Tapped="OnTweaksBodyTapped"/>
				</Border.GestureRecognizers>
				<VerticalStackLayout Spacing="14">
					<Label
						AutomationId="OriginalTimetable.V6.Tweaks.Title"
						Text="表示設定"
						FontSize="13"
						FontAttributes="Bold"
						TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
					<Grid ColumnDefinitions="*,Auto">
						<Label
							Grid.Column="0"
							Text="通過駅を表示"
							FontSize="13"
							VerticalOptions="Center"
							TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
						<Switch
							Grid.Column="1"
							AutomationId="OriginalTimetable.V6.Tweaks.ShowPasses"
							IsToggled="{Binding ShowPasses, Mode=TwoWay}"/>
					</Grid>
					<VerticalStackLayout Spacing="4">
						<Label
							Text="行間"
							FontSize="12"
							TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
						<HorizontalStackLayout Spacing="6">
							<Border
								x:Name="DensityCompact"
								AutomationId="OriginalTimetable.V6.Tweaks.Density.Compact"
								StrokeShape="RoundRectangle 6"
								StrokeThickness="0"
								Padding="10,4"
								Background="{StaticResource OT_BgSoft}">
								<Border.GestureRecognizers>
									<TapGestureRecognizer Tapped="OnDensityCompactTapped"/>
								</Border.GestureRecognizers>
								<Label x:Name="DensityCompactLabel" Text="狭" FontSize="12"
									TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
							</Border>
							<Border
								x:Name="DensityComfortable"
								AutomationId="OriginalTimetable.V6.Tweaks.Density.Comfortable"
								StrokeShape="RoundRectangle 6"
								StrokeThickness="0"
								Padding="10,4"
								Background="{StaticResource OT_BgSoft}">
								<Border.GestureRecognizers>
									<TapGestureRecognizer Tapped="OnDensityComfortableTapped"/>
								</Border.GestureRecognizers>
								<Label x:Name="DensityComfortableLabel" Text="標準" FontSize="12"
									TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
							</Border>
							<Border
								x:Name="DensitySpacious"
								AutomationId="OriginalTimetable.V6.Tweaks.Density.Spacious"
								StrokeShape="RoundRectangle 6"
								StrokeThickness="0"
								Padding="10,4"
								Background="{StaticResource OT_BgSoft}">
								<Border.GestureRecognizers>
									<TapGestureRecognizer Tapped="OnDensitySpaciousTapped"/>
								</Border.GestureRecognizers>
								<Label x:Name="DensitySpaciousLabel" Text="広" FontSize="12"
									TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
							</Border>
						</HorizontalStackLayout>
					</VerticalStackLayout>
				</VerticalStackLayout>
			</Border>
		</Grid>
	</Grid>
</ContentPage>
