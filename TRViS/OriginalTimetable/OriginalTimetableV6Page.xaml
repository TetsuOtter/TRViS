<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
	xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
	xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
	xmlns:local="clr-namespace:TRViS.OriginalTimetable"
	x:Class="TRViS.OriginalTimetable.OriginalTimetableV6Page"
	x:Name="Self"
	Title="ダイヤ表 (V6)"
	SizeChanged="OnRootSizeChanged"
	BackgroundColor="{AppThemeBinding Light={StaticResource OT_Bg_Light}, Dark={StaticResource OT_Bg_Dark}}">
	<Grid x:Name="RootGrid" AutomationId="OriginalTimetable.V6.Root">

		<!-- Tablet layout (>= 600pt) -->
		<Grid
			x:Name="TabletGrid"
			AutomationId="OriginalTimetable.V6.TabletGrid"
			RowDefinitions="Auto,Auto,Auto,Auto,*"
			IsVisible="False">

			<!-- Row 0: Masthead -->
			<Border
				Grid.Row="0"
				AutomationId="OriginalTimetable.V6.Masthead"
				Padding="16,12"
				StrokeThickness="0,0,0,2"
				Stroke="{StaticResource OT_Fg}"
				Background="{StaticResource OT_Bg}"
				StrokeShape="Rectangle">
				<VerticalStackLayout Spacing="2">
					<Label
						Text="{Binding DepotName, Source={x:Reference Self}}"
						FontSize="11"
						FontAttributes="Bold"
						CharacterSpacing="2"
						TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
					<HorizontalStackLayout Spacing="10">
						<Label
							Text="{Binding RouteNameText, Source={x:Reference Self}}"
							FontSize="22"
							FontAttributes="Bold"
							TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
						<Label
							Text="{Binding WorkDateText, Source={x:Reference Self}}"
							FontSize="13"
							VerticalOptions="Center"
							TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
					</HorizontalStackLayout>
				</VerticalStackLayout>
			</Border>

			<!-- Row 1: Train stripe (full-bleed) -->
			<Border
				Grid.Row="1"
				AutomationId="OriginalTimetable.V6.TrainStripe"
				Padding="16,12"
				StrokeThickness="0"
				StrokeShape="Rectangle"
				Background="{StaticResource OT_Accent}">
				<Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="14">
					<Label
						Grid.Column="0"
						Text="{Binding TrainNumberText, Source={x:Reference Self}}"
						FontSize="28"
						FontAttributes="Bold"
						FontFamily="Menlo"
						VerticalOptions="Center"
						TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"/>
					<VerticalStackLayout Grid.Column="2" Spacing="0" VerticalOptions="Center">
						<Label
							Text="CARS"
							FontSize="10"
							CharacterSpacing="2"
							TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"
							Opacity="0.7"/>
						<Label
							Text="{Binding CarCountText, Source={x:Reference Self}}"
							FontSize="16"
							FontAttributes="Bold"
							TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"/>
					</VerticalStackLayout>
					<VerticalStackLayout Grid.Column="3" Spacing="0" VerticalOptions="Center">
						<Label
							Text="MAX"
							FontSize="10"
							CharacterSpacing="2"
							TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"
							Opacity="0.7"/>
						<Label
							Text="{Binding MaxSpeedText, Source={x:Reference Self}}"
							FontSize="16"
							FontAttributes="Bold"
							TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"/>
					</VerticalStackLayout>
					<VerticalStackLayout Grid.Column="4" Spacing="0" VerticalOptions="Center">
						<Label
							Text="DEST"
							FontSize="10"
							CharacterSpacing="2"
							TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"
							Opacity="0.7"/>
						<Label
							Text="{Binding DestinationText, Source={x:Reference Self}}"
							FontSize="16"
							FontAttributes="Bold"
							TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"/>
					</VerticalStackLayout>
				</Grid>
			</Border>

			<!-- Row 2: Past chips -->
			<Border
				Grid.Row="2"
				AutomationId="OriginalTimetable.V6.PastChips"
				Padding="16,8"
				StrokeThickness="0,0,0,1"
				Stroke="{StaticResource OT_Rule}"
				StrokeShape="Rectangle"
				Background="{StaticResource OT_Bg}">
				<ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
					<HorizontalStackLayout Spacing="6" VerticalOptions="Center">
						<Label
							Text="済"
							FontSize="11"
							VerticalOptions="Center"
							TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
						<Label
							Text="—"
							FontSize="11"
							VerticalOptions="Center"
							IsVisible="{Binding HasNoPastChips, Source={x:Reference Self}}"
							TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
						<BindableLayout.ItemsSource>
							<Binding Path="PastChips" Source="{x:Reference Self}"/>
						</BindableLayout.ItemsSource>
						<BindableLayout.ItemTemplate>
							<DataTemplate x:DataType="local:V6PastChipItem">
								<Border
									AutomationId="{Binding ChipAutomationId}"
									Padding="6,2"
									StrokeThickness="0"
									StrokeShape="RoundRectangle 10"
									Background="{StaticResource OT_BgSoft}"
									VerticalOptions="Center">
									<Label
										Text="{Binding StationName}"
										FontSize="11"
										TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
								</Border>
							</DataTemplate>
						</BindableLayout.ItemTemplate>
					</HorizontalStackLayout>
				</ScrollView>
			</Border>

			<!-- Row 3: Current big block -->
			<SwipeView
				Grid.Row="3"
				AutomationId="OriginalTimetable.V6.CurrentBlock"
				IsVisible="{Binding HasCurrentStation, Source={x:Reference Self}}">
				<SwipeView.RightItems>
					<SwipeItems Mode="Reveal">
						<SwipeItem
							Text="マーカー"
							BackgroundColor="{AppThemeBinding Light={StaticResource OT_Accent_Light}, Dark={StaticResource OT_Accent_Dark}}"
							Command="{Binding OpenMarkerPopoverFromSwipeCommand, Source={x:Reference Self}}"
							CommandParameter="{Binding CurrentRowId, Source={x:Reference Self}}"/>
						<SwipeItem
							Text="メモ"
							BackgroundColor="{StaticResource OT_MarkerCautionBg}"
							Command="{Binding OpenMemoCommand, Source={x:Reference Self}}"
							CommandParameter="{Binding CurrentRowId, Source={x:Reference Self}}"/>
						<SwipeItem
							Text="クリア"
							BackgroundColor="{AppThemeBinding Light={StaticResource OT_AccentSoft_Light}, Dark={StaticResource OT_AccentSoft_Dark}}"
							Command="{Binding ClearMarkerCommand, Source={x:Reference Self}}"
							CommandParameter="{Binding CurrentRowId, Source={x:Reference Self}}"/>
					</SwipeItems>
				</SwipeView.RightItems>
				<Border
					Padding="24,20"
					StrokeThickness="0,1,0,1"
					Stroke="{StaticResource OT_Accent}"
					StrokeShape="Rectangle"
					Background="{StaticResource OT_AccentSoft}">
					<VerticalStackLayout Spacing="10">
						<Label
							Text="NOW APPROACHING"
							FontSize="11"
							FontAttributes="Bold"
							CharacterSpacing="3"
							TextColor="{AppThemeBinding Light={StaticResource OT_AccentFgStrong_Light}, Dark={StaticResource OT_AccentFgStrong_Dark}}"/>
						<Label
							AutomationId="OriginalTimetable.V6.CurrentBlock.StationName"
							Text="{Binding CurrentStationName, Source={x:Reference Self}}"
							FontSize="48"
							FontAttributes="Bold"
							TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
						<Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="18">
							<VerticalStackLayout Grid.Column="0" Spacing="2">
								<Label
									Text="着"
									FontSize="11"
									CharacterSpacing="2"
									TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
								<Label
									Text="{Binding CurrentStationArrive, Source={x:Reference Self}}"
									FontSize="28"
									FontAttributes="Bold"
									FontFamily="Menlo"
									TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
							</VerticalStackLayout>
							<VerticalStackLayout Grid.Column="1" Spacing="2">
								<Label
									Text="発"
									FontSize="11"
									CharacterSpacing="2"
									TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
								<Label
									Text="{Binding CurrentStationDepart, Source={x:Reference Self}}"
									FontSize="28"
									FontAttributes="Bold"
									FontFamily="Menlo"
									TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
							</VerticalStackLayout>
							<Border
								Grid.Column="3"
								IsVisible="{Binding HasCurrentStationTrack, Source={x:Reference Self}}"
								WidthRequest="64"
								HeightRequest="64"
								StrokeThickness="3"
								Stroke="{StaticResource OT_Fg}"
								StrokeShape="Rectangle"
								BackgroundColor="Transparent"
								VerticalOptions="End">
								<Label
									Text="{Binding CurrentStationTrack, Source={x:Reference Self}}"
									FontSize="32"
									FontAttributes="Bold"
									FontFamily="Menlo"
									HorizontalOptions="Center"
									VerticalOptions="Center"
									TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
							</Border>
						</Grid>
					</VerticalStackLayout>
				</Border>
			</SwipeView>

			<!-- Empty-state when ActiveTrain is null -->
			<Label
				Grid.Row="4"
				AutomationId="OriginalTimetable.V6.EmptyState"
				IsVisible="{Binding HasNoActiveTrain, Source={x:Reference Self}}"
				Text="列車を選択してください"
				FontSize="16"
				HorizontalOptions="Center"
				VerticalOptions="Center"
				TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>

			<!-- Row 4: Upcoming list -->
			<CollectionView
				x:Name="TabletUpcomingList"
				Grid.Row="4"
				AutomationId="OriginalTimetable.V6.UpcomingList"
				IsVisible="{Binding HasActiveTrain, Source={x:Reference Self}}"
				ItemsSource="{Binding Items, Source={x:Reference Self}}"
				SelectionMode="None">
				<CollectionView.ItemTemplate>
					<DataTemplate x:DataType="local:V6RowItem">
						<SwipeView AutomationId="{Binding RowAutomationId}">
							<SwipeView.RightItems>
								<SwipeItems Mode="Reveal">
									<SwipeItem
										AutomationId="{Binding MarkerAutomationId}"
										Text="マーカー"
										BackgroundColor="{AppThemeBinding Light={StaticResource OT_Accent_Light}, Dark={StaticResource OT_Accent_Dark}}"
										Command="{Binding OpenMarkerPopoverFromSwipeCommand, Source={x:Reference Self}}"
										CommandParameter="{Binding Id}"/>
									<SwipeItem
										AutomationId="{Binding MemoAutomationId}"
										Text="メモ"
										BackgroundColor="{StaticResource OT_MarkerCautionBg}"
										Command="{Binding OpenMemoCommand, Source={x:Reference Self}}"
										CommandParameter="{Binding Id}"/>
									<SwipeItem
										AutomationId="{Binding ClearAutomationId}"
										Text="クリア"
										BackgroundColor="{AppThemeBinding Light={StaticResource OT_AccentSoft_Light}, Dark={StaticResource OT_AccentSoft_Dark}}"
										Command="{Binding ClearMarkerCommand, Source={x:Reference Self}}"
										CommandParameter="{Binding Id}"/>
								</SwipeItems>
							</SwipeView.RightItems>
							<VerticalStackLayout Spacing="0">
								<!-- Section break row (double-rule editorial style) -->
								<Border
									IsVisible="{Binding IsSectionBreakRow}"
									Padding="16,10"
									StrokeThickness="0,2,0,2"
									Stroke="{StaticResource OT_Fg}"
									Margin="0,6,0,0"
									StrokeShape="Rectangle"
									Background="{StaticResource OT_Bg}">
									<Label
										Text="{Binding SectionBreakLabel}"
										FontSize="15"
										FontAttributes="Bold"
										TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
								</Border>

								<!-- Normal row -->
								<Border
									IsVisible="{Binding IsNormalRow}"
									StrokeThickness="0,0,0,1"
									Stroke="{StaticResource OT_Rule}"
									StrokeShape="Rectangle"
									Padding="16,10"
									Background="{StaticResource OT_Bg}">
									<Grid
										ColumnDefinitions="44,*,80,80,50"
										ColumnSpacing="8">
										<Label
											Grid.Column="0"
											Text="{Binding CounterText}"
											FontSize="16"
											FontAttributes="Bold"
											FontFamily="Menlo"
											VerticalOptions="Center"
											TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
										<HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
											<Label
												Text="{Binding StationName}"
												FontSize="22"
												FontAttributes="Bold"
												VerticalOptions="Center"
												TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}">
												<Label.Triggers>
													<DataTrigger TargetType="Label" Binding="{Binding IsPass}" Value="True">
														<Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
														<Setter Property="FontSize" Value="16"/>
														<Setter Property="FontAttributes" Value="None"/>
													</DataTrigger>
												</Label.Triggers>
											</Label>
											<!-- Marker badge -->
											<Border
												AutomationId="{Binding MarkerBadgeAutomationId}"
												IsVisible="{Binding HasMarker}"
												Padding="6,1"
												StrokeThickness="0"
												StrokeShape="RoundRectangle 4"
												VerticalOptions="Center"
												Background="{StaticResource OT_Bg}">
												<Border.GestureRecognizers>
													<TapGestureRecognizer Tapped="OnMarkerBadgeTapped"/>
												</Border.GestureRecognizers>
												<Border.Triggers>
													<DataTrigger TargetType="Border" Binding="{Binding IsMarkerFlag}" Value="True">
														<Setter Property="Background" Value="{StaticResource OT_MarkerFlagBgBrush}"/>
													</DataTrigger>
													<DataTrigger TargetType="Border" Binding="{Binding IsMarkerCaution}" Value="True">
														<Setter Property="Background" Value="{StaticResource OT_MarkerCautionBgBrush}"/>
													</DataTrigger>
													<DataTrigger TargetType="Border" Binding="{Binding IsMarkerStar}" Value="True">
														<Setter Property="Background" Value="{StaticResource OT_MarkerStarBgBrush}"/>
													</DataTrigger>
												</Border.Triggers>
												<Label
													Text="{Binding MarkerText}"
													FontSize="11"
													FontAttributes="Bold"
													TextColor="{StaticResource OT_MarkerFlagFg}">
													<Label.Triggers>
														<DataTrigger TargetType="Label" Binding="{Binding IsMarkerCaution}" Value="True">
															<Setter Property="TextColor" Value="{StaticResource OT_MarkerCautionFg}"/>
														</DataTrigger>
														<DataTrigger TargetType="Label" Binding="{Binding IsMarkerStar}" Value="True">
															<Setter Property="TextColor" Value="{StaticResource OT_MarkerStarFg}"/>
														</DataTrigger>
													</Label.Triggers>
												</Label>
											</Border>
											<!-- Memo dot -->
											<Ellipse
												IsVisible="{Binding HasMemo}"
												WidthRequest="8"
												HeightRequest="8"
												Fill="{AppThemeBinding Light={StaticResource OT_AccentFgStrong_Light}, Dark={StaticResource OT_AccentFgStrong_Dark}}"
												VerticalOptions="Center"/>
										</HorizontalStackLayout>
										<Label
											Grid.Column="2"
											Text="{Binding ArriveText}"
											FontSize="18"
											FontFamily="Menlo"
											VerticalOptions="Center"
											HorizontalOptions="End"
											TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
										<Label
											Grid.Column="3"
											Text="{Binding DepartText}"
											FontSize="18"
											FontAttributes="Bold"
											FontFamily="Menlo"
											VerticalOptions="Center"
											HorizontalOptions="End"
											TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
										<Border
											Grid.Column="4"
											IsVisible="{Binding HasTrackName}"
											StrokeThickness="2"
											Stroke="{StaticResource OT_Fg}"
											StrokeShape="Rectangle"
											BackgroundColor="Transparent"
											WidthRequest="40"
											HeightRequest="40"
											VerticalOptions="Center"
											HorizontalOptions="Center">
											<Label
												Text="{Binding TrackName}"
												FontSize="16"
												FontAttributes="Bold"
												FontFamily="Menlo"
												HorizontalOptions="Center"
												VerticalOptions="Center"
												TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
										</Border>
									</Grid>
								</Border>
							</VerticalStackLayout>
						</SwipeView>
					</DataTemplate>
				</CollectionView.ItemTemplate>
			</CollectionView>
		</Grid>

		<!-- Compact layout (< 600pt) — mirrors TabletGrid structure with smaller fonts. -->
		<Grid
			x:Name="CompactGrid"
			AutomationId="OriginalTimetable.V6.CompactGrid"
			RowDefinitions="Auto,Auto,Auto,Auto,*"
			IsVisible="False">

			<!-- Row 0: Masthead (compact) -->
			<Border
				Grid.Row="0"
				AutomationId="OriginalTimetable.V6.Compact.Masthead"
				Padding="12,8"
				StrokeThickness="0,0,0,2"
				Stroke="{StaticResource OT_Fg}"
				Background="{StaticResource OT_Bg}"
				StrokeShape="Rectangle">
				<VerticalStackLayout Spacing="1">
					<Label
						Text="{Binding DepotName, Source={x:Reference Self}}"
						FontSize="10"
						FontAttributes="Bold"
						CharacterSpacing="2"
						TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
					<HorizontalStackLayout Spacing="6">
						<Label
							Text="{Binding RouteNameText, Source={x:Reference Self}}"
							FontSize="17"
							FontAttributes="Bold"
							TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
						<Label
							Text="{Binding WorkDateText, Source={x:Reference Self}}"
							FontSize="11"
							VerticalOptions="Center"
							TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
					</HorizontalStackLayout>
				</VerticalStackLayout>
			</Border>

			<!-- Row 1: Train stripe (compact) -->
			<Border
				Grid.Row="1"
				AutomationId="OriginalTimetable.V6.Compact.TrainStripe"
				Padding="12,8"
				StrokeThickness="0"
				StrokeShape="Rectangle"
				Background="{StaticResource OT_Accent}">
				<Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="8">
					<Label
						Grid.Column="0"
						Text="{Binding TrainNumberText, Source={x:Reference Self}}"
						FontSize="22"
						FontAttributes="Bold"
						FontFamily="Menlo"
						VerticalOptions="Center"
						TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"/>
					<VerticalStackLayout Grid.Column="2" Spacing="0" VerticalOptions="Center">
						<Label
							Text="CARS"
							FontSize="9"
							CharacterSpacing="2"
							TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"
							Opacity="0.7"/>
						<Label
							Text="{Binding CarCountText, Source={x:Reference Self}}"
							FontSize="13"
							FontAttributes="Bold"
							TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"/>
					</VerticalStackLayout>
					<VerticalStackLayout Grid.Column="3" Spacing="0" VerticalOptions="Center">
						<Label
							Text="MAX"
							FontSize="9"
							CharacterSpacing="2"
							TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"
							Opacity="0.7"/>
						<Label
							Text="{Binding MaxSpeedText, Source={x:Reference Self}}"
							FontSize="13"
							FontAttributes="Bold"
							TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"/>
					</VerticalStackLayout>
					<VerticalStackLayout Grid.Column="4" Spacing="0" VerticalOptions="Center">
						<Label
							Text="DEST"
							FontSize="9"
							CharacterSpacing="2"
							TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"
							Opacity="0.7"/>
						<Label
							Text="{Binding DestinationText, Source={x:Reference Self}}"
							FontSize="13"
							FontAttributes="Bold"
							LineBreakMode="TailTruncation"
							TextColor="{AppThemeBinding Light={StaticResource OT_AccentFg_Light}, Dark={StaticResource OT_AccentFg_Dark}}"/>
					</VerticalStackLayout>
				</Grid>
			</Border>

			<!-- Row 2: Past chips (compact) -->
			<Border
				Grid.Row="2"
				AutomationId="OriginalTimetable.V6.Compact.PastChips"
				Padding="12,6"
				StrokeThickness="0,0,0,1"
				Stroke="{StaticResource OT_Rule}"
				StrokeShape="Rectangle"
				Background="{StaticResource OT_Bg}">
				<ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
					<HorizontalStackLayout Spacing="4" VerticalOptions="Center">
						<Label
							Text="済"
							FontSize="10"
							VerticalOptions="Center"
							TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
						<Label
							Text="—"
							FontSize="10"
							VerticalOptions="Center"
							IsVisible="{Binding HasNoPastChips, Source={x:Reference Self}}"
							TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
						<BindableLayout.ItemsSource>
							<Binding Path="PastChips" Source="{x:Reference Self}"/>
						</BindableLayout.ItemsSource>
						<BindableLayout.ItemTemplate>
							<DataTemplate x:DataType="local:V6PastChipItem">
								<Border
									AutomationId="{Binding ChipAutomationId}"
									Padding="5,1"
									StrokeThickness="0"
									StrokeShape="RoundRectangle 8"
									Background="{StaticResource OT_BgSoft}"
									VerticalOptions="Center">
									<Label
										Text="{Binding StationName}"
										FontSize="10"
										TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
								</Border>
							</DataTemplate>
						</BindableLayout.ItemTemplate>
					</HorizontalStackLayout>
				</ScrollView>
			</Border>

			<!-- Row 3: Current big block (compact) -->
			<SwipeView
				Grid.Row="3"
				AutomationId="OriginalTimetable.V6.Compact.CurrentBlock"
				IsVisible="{Binding HasCurrentStation, Source={x:Reference Self}}">
				<SwipeView.RightItems>
					<SwipeItems Mode="Reveal">
						<SwipeItem
							Text="マーカー"
							BackgroundColor="{AppThemeBinding Light={StaticResource OT_Accent_Light}, Dark={StaticResource OT_Accent_Dark}}"
							Command="{Binding OpenMarkerPopoverFromSwipeCommand, Source={x:Reference Self}}"
							CommandParameter="{Binding CurrentRowId, Source={x:Reference Self}}"/>
						<SwipeItem
							Text="メモ"
							BackgroundColor="{StaticResource OT_MarkerCautionBg}"
							Command="{Binding OpenMemoCommand, Source={x:Reference Self}}"
							CommandParameter="{Binding CurrentRowId, Source={x:Reference Self}}"/>
						<SwipeItem
							Text="クリア"
							BackgroundColor="{AppThemeBinding Light={StaticResource OT_AccentSoft_Light}, Dark={StaticResource OT_AccentSoft_Dark}}"
							Command="{Binding ClearMarkerCommand, Source={x:Reference Self}}"
							CommandParameter="{Binding CurrentRowId, Source={x:Reference Self}}"/>
					</SwipeItems>
				</SwipeView.RightItems>
				<Border
					Padding="14,14"
					StrokeThickness="0,1,0,1"
					Stroke="{StaticResource OT_Accent}"
					StrokeShape="Rectangle"
					Background="{StaticResource OT_AccentSoft}">
					<VerticalStackLayout Spacing="8">
						<Label
							Text="NOW APPROACHING"
							FontSize="10"
							FontAttributes="Bold"
							CharacterSpacing="3"
							TextColor="{AppThemeBinding Light={StaticResource OT_AccentFgStrong_Light}, Dark={StaticResource OT_AccentFgStrong_Dark}}"/>
						<Label
							Text="{Binding CurrentStationName, Source={x:Reference Self}}"
							FontSize="34"
							FontAttributes="Bold"
							TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
						<Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="14">
							<VerticalStackLayout Grid.Column="0" Spacing="2">
								<Label
									Text="着"
									FontSize="10"
									CharacterSpacing="2"
									TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
								<Label
									Text="{Binding CurrentStationArrive, Source={x:Reference Self}}"
									FontSize="22"
									FontAttributes="Bold"
									FontFamily="Menlo"
									TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
							</VerticalStackLayout>
							<VerticalStackLayout Grid.Column="1" Spacing="2">
								<Label
									Text="発"
									FontSize="10"
									CharacterSpacing="2"
									TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
								<Label
									Text="{Binding CurrentStationDepart, Source={x:Reference Self}}"
									FontSize="22"
									FontAttributes="Bold"
									FontFamily="Menlo"
									TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
							</VerticalStackLayout>
							<Border
								Grid.Column="3"
								IsVisible="{Binding HasCurrentStationTrack, Source={x:Reference Self}}"
								WidthRequest="48"
								HeightRequest="48"
								StrokeThickness="3"
								Stroke="{StaticResource OT_Fg}"
								StrokeShape="Rectangle"
								BackgroundColor="Transparent"
								VerticalOptions="End">
								<Label
									Text="{Binding CurrentStationTrack, Source={x:Reference Self}}"
									FontSize="24"
									FontAttributes="Bold"
									FontFamily="Menlo"
									HorizontalOptions="Center"
									VerticalOptions="Center"
									TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
							</Border>
						</Grid>
					</VerticalStackLayout>
				</Border>
			</SwipeView>

			<!-- Empty-state -->
			<Label
				Grid.Row="4"
				AutomationId="OriginalTimetable.V6.Compact.EmptyState"
				IsVisible="{Binding HasNoActiveTrain, Source={x:Reference Self}}"
				Text="列車を選択してください"
				FontSize="14"
				HorizontalOptions="Center"
				VerticalOptions="Center"
				TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>

			<!-- Row 4: Upcoming list (compact) -->
			<CollectionView
				x:Name="CompactUpcomingList"
				Grid.Row="4"
				AutomationId="OriginalTimetable.V6.Compact.UpcomingList"
				IsVisible="{Binding HasActiveTrain, Source={x:Reference Self}}"
				ItemsSource="{Binding Items, Source={x:Reference Self}}"
				SelectionMode="None">
				<CollectionView.ItemTemplate>
					<DataTemplate x:DataType="local:V6RowItem">
						<SwipeView AutomationId="{Binding RowAutomationId}">
							<SwipeView.RightItems>
								<SwipeItems Mode="Reveal">
									<SwipeItem
										AutomationId="{Binding MarkerAutomationId}"
										Text="マーカー"
										BackgroundColor="{AppThemeBinding Light={StaticResource OT_Accent_Light}, Dark={StaticResource OT_Accent_Dark}}"
										Command="{Binding OpenMarkerPopoverFromSwipeCommand, Source={x:Reference Self}}"
										CommandParameter="{Binding Id}"/>
									<SwipeItem
										AutomationId="{Binding MemoAutomationId}"
										Text="メモ"
										BackgroundColor="{StaticResource OT_MarkerCautionBg}"
										Command="{Binding OpenMemoCommand, Source={x:Reference Self}}"
										CommandParameter="{Binding Id}"/>
									<SwipeItem
										AutomationId="{Binding ClearAutomationId}"
										Text="クリア"
										BackgroundColor="{AppThemeBinding Light={StaticResource OT_AccentSoft_Light}, Dark={StaticResource OT_AccentSoft_Dark}}"
										Command="{Binding ClearMarkerCommand, Source={x:Reference Self}}"
										CommandParameter="{Binding Id}"/>
								</SwipeItems>
							</SwipeView.RightItems>
							<VerticalStackLayout Spacing="0">
								<!-- Section break (compact) -->
								<Border
									IsVisible="{Binding IsSectionBreakRow}"
									Padding="12,8"
									StrokeThickness="0,2,0,2"
									Stroke="{StaticResource OT_Fg}"
									Margin="0,4,0,0"
									StrokeShape="Rectangle"
									Background="{StaticResource OT_Bg}">
									<Label
										Text="{Binding SectionBreakLabel}"
										FontSize="13"
										FontAttributes="Bold"
										TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
								</Border>

								<!-- Normal row (compact) -->
								<Border
									IsVisible="{Binding IsNormalRow}"
									StrokeThickness="0,0,0,1"
									Stroke="{StaticResource OT_Rule}"
									StrokeShape="Rectangle"
									Padding="12,8"
									Background="{StaticResource OT_Bg}">
									<Grid
										ColumnDefinitions="36,*,64,64,40"
										ColumnSpacing="6">
										<Label
											Grid.Column="0"
											Text="{Binding CounterText}"
											FontSize="13"
											FontAttributes="Bold"
											FontFamily="Menlo"
											VerticalOptions="Center"
											TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
										<HorizontalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
											<Label
												Text="{Binding StationName}"
												FontSize="16"
												FontAttributes="Bold"
												VerticalOptions="Center"
												TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}">
												<Label.Triggers>
													<DataTrigger TargetType="Label" Binding="{Binding IsPass}" Value="True">
														<Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
														<Setter Property="FontSize" Value="13"/>
														<Setter Property="FontAttributes" Value="None"/>
													</DataTrigger>
												</Label.Triggers>
											</Label>
											<!-- Marker badge -->
											<Border
												AutomationId="{Binding MarkerBadgeAutomationId}"
												IsVisible="{Binding HasMarker}"
												Padding="5,1"
												StrokeThickness="0"
												StrokeShape="RoundRectangle 4"
												VerticalOptions="Center"
												Background="{StaticResource OT_Bg}">
												<Border.GestureRecognizers>
													<TapGestureRecognizer Tapped="OnMarkerBadgeTapped"/>
												</Border.GestureRecognizers>
												<Border.Triggers>
													<DataTrigger TargetType="Border" Binding="{Binding IsMarkerFlag}" Value="True">
														<Setter Property="Background" Value="{StaticResource OT_MarkerFlagBgBrush}"/>
													</DataTrigger>
													<DataTrigger TargetType="Border" Binding="{Binding IsMarkerCaution}" Value="True">
														<Setter Property="Background" Value="{StaticResource OT_MarkerCautionBgBrush}"/>
													</DataTrigger>
													<DataTrigger TargetType="Border" Binding="{Binding IsMarkerStar}" Value="True">
														<Setter Property="Background" Value="{StaticResource OT_MarkerStarBgBrush}"/>
													</DataTrigger>
												</Border.Triggers>
												<Label
													Text="{Binding MarkerText}"
													FontSize="10"
													FontAttributes="Bold"
													TextColor="{StaticResource OT_MarkerFlagFg}">
													<Label.Triggers>
														<DataTrigger TargetType="Label" Binding="{Binding IsMarkerCaution}" Value="True">
															<Setter Property="TextColor" Value="{StaticResource OT_MarkerCautionFg}"/>
														</DataTrigger>
														<DataTrigger TargetType="Label" Binding="{Binding IsMarkerStar}" Value="True">
															<Setter Property="TextColor" Value="{StaticResource OT_MarkerStarFg}"/>
														</DataTrigger>
													</Label.Triggers>
												</Label>
											</Border>
											<!-- Memo dot -->
											<Ellipse
												IsVisible="{Binding HasMemo}"
												WidthRequest="7"
												HeightRequest="7"
												Fill="{AppThemeBinding Light={StaticResource OT_AccentFgStrong_Light}, Dark={StaticResource OT_AccentFgStrong_Dark}}"
												VerticalOptions="Center"/>
										</HorizontalStackLayout>
										<Label
											Grid.Column="2"
											Text="{Binding ArriveText}"
											FontSize="14"
											FontFamily="Menlo"
											VerticalOptions="Center"
											HorizontalOptions="End"
											TextColor="{AppThemeBinding Light={StaticResource OT_Muted_Light}, Dark={StaticResource OT_Muted_Dark}}"/>
										<Label
											Grid.Column="3"
											Text="{Binding DepartText}"
											FontSize="14"
											FontAttributes="Bold"
											FontFamily="Menlo"
											VerticalOptions="Center"
											HorizontalOptions="End"
											TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
										<Border
											Grid.Column="4"
											IsVisible="{Binding HasTrackName}"
											StrokeThickness="2"
											Stroke="{StaticResource OT_Fg}"
											StrokeShape="Rectangle"
											BackgroundColor="Transparent"
											WidthRequest="32"
											HeightRequest="32"
											VerticalOptions="Center"
											HorizontalOptions="Center">
											<Label
												Text="{Binding TrackName}"
												FontSize="13"
												FontAttributes="Bold"
												FontFamily="Menlo"
												HorizontalOptions="Center"
												VerticalOptions="Center"
												TextColor="{AppThemeBinding Light={StaticResource OT_Fg_Light}, Dark={StaticResource OT_Fg_Dark}}"/>
										</Border>
									</Grid>
								</Border>
							</VerticalStackLayout>
						</SwipeView>
					</DataTemplate>
				</CollectionView.ItemTemplate>
			</CollectionView>
		</Grid>
	</Grid>
</ContentPage>
