<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
	xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
	xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
	xmlns:local="clr-namespace:TRViS">

	<Style x:Key="PrimaryActionButton"
				 TargetType="Button">
		<Setter Property="HeightRequest"
						Value="80"/>
		<Setter Property="MinimumWidthRequest"
						Value="200"/>
		<Setter Property="FontSize"
						Value="20"/>
		<Setter Property="FontAttributes"
						Value="Bold"/>
		<Setter Property="CornerRadius"
						Value="12"/>
		<Setter Property="Margin"
						Value="6"/>
		<Setter Property="Padding"
						Value="16,8"/>
		<Setter Property="FlexLayout.Grow"
						Value="1"/>
		<Setter Property="FlexLayout.Basis"
						Value="220"/>
	</Style>

	<Style x:Key="SecondaryActionButton"
				 TargetType="Button">
		<Setter Property="FontSize"
						Value="14"/>
		<Setter Property="HeightRequest"
						Value="44"/>
		<Setter Property="CornerRadius"
						Value="8"/>
		<Setter Property="Margin"
						Value="4"/>
		<Setter Property="HorizontalOptions"
						Value="Center"/>
		<Setter Property="MinimumWidthRequest"
						Value="180"/>
	</Style>

	<Style x:Key="LinkButton"
				 TargetType="Button">
		<Setter Property="BackgroundColor"
						Value="Transparent"/>
		<Setter Property="TextColor"
						Value="{x:Static local:RootStyles.TableTextColor}"/>
		<Setter Property="FontSize"
						Value="13"/>
		<Setter Property="Padding"
						Value="8,4"/>
		<Setter Property="Margin"
						Value="2,0"/>
		<Setter Property="HeightRequest"
						Value="32"/>
	</Style>

	<Style x:Key="StepListBorder"
				 TargetType="Border">
		<Setter Property="Stroke"
						Value="{x:Static local:RootStyles.BorderStrokeColor}"/>
		<Setter Property="BackgroundColor"
						Value="{x:Static local:RootStyles.BackgroundColor}"/>
		<Setter Property="Margin"
						Value="0,0,0,4"/>
		<Setter Property="Padding"
						Value="8"/>
		<Setter Property="StrokeShape">
			<RoundRectangle CornerRadius="8"/>
		</Setter>
	</Style>

	<Style x:Key="StepChipBorder"
				 TargetType="Border">
		<Setter Property="Stroke"
						Value="{x:Static local:RootStyles.BorderStrokeColor}"/>
		<Setter Property="StrokeThickness"
						Value="1"/>
		<Setter Property="BackgroundColor"
						Value="{x:Static local:RootStyles.BackgroundBlackWhite}"/>
		<Setter Property="Margin"
						Value="0,0,0,4"/>
		<Setter Property="Padding"
						Value="12,8"/>
		<Setter Property="StrokeShape">
			<RoundRectangle CornerRadius="8"/>
		</Setter>
	</Style>

</ResourceDictionary>
