<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
	xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
	xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
	xmlns:viewmodels="clr-namespace:TRViS.ViewModels"
	xmlns:converters="clr-namespace:TRViS.ValueConverters"
	xmlns:loc="clr-namespace:TRViS.Localization"
	x:DataType="viewmodels:EasterEggPageViewModel"
	x:Class="TRViS.RootPages.EasterEggPage"
	Title="{loc:Translate Settings_Title}">
	<ContentPage.Resources>
		<ResourceDictionary>
			<converters:DoubleToIntConverter x:Key="DoubleToIntConverter"/>

			<Style TargetType="Slider">
				<Setter
					Property="Minimum"
					Value="0"/>
				<Setter
					Property="Maximum"
					Value="255"/>
				<Setter
					Property="Margin"
					Value="4"/>
			</Style>

			<Style TargetType="Border">
				<Setter
					Property="Margin"
					Value="8"/>
				<Setter
					Property="Padding"
					Value="8"/>
				<Setter
					Property="Stroke"
					Value="{AppThemeBinding Default=Black,Dark=White}"/>
			</Style>

			<Style TargetType="Button">
				<Setter
					Property="Margin"
					Value="8"/>
				<Setter
					Property="Padding"
					Value="8"/>
				<Setter
					Property="LineBreakMode"
					Value="WordWrap"/>
			</Style>
		</ResourceDictionary>
	</ContentPage.Resources>

	<ScrollView>
		<VerticalStackLayout Margin="4,8">
			<HorizontalStackLayout
				IsVisible="false"
				HorizontalOptions="Start">
				<Button
					Text="Load from..."
					Clicked="OnLoadFromPickerClicked"/>
				<Button
					Text="Save to..."
					Clicked="OnSaveToPickerClicked"/>
			</HorizontalStackLayout>
			<HorizontalStackLayout
				HorizontalOptions="End">
				<Button
					AutomationId="Settings.ReloadSavedButton"
					Text="{loc:Translate Settings_ReloadSaved}"
					Clicked="OnReloadSavedClicked"/>
				<Button
					AutomationId="Settings.SaveButton"
					Text="{loc:Translate Settings_Save}"
					Clicked="OnSaveClicked"/>
			</HorizontalStackLayout>
			<Border>
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="*"/>
						<RowDefinition Height="*"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="90"/>
					</Grid.ColumnDefinitions>

					<Slider
						Grid.Column="0"
						Grid.Row="0"
						Value="{Binding Color_Red, Converter={StaticResource DoubleToIntConverter}}"
						ThumbColor="Red"/>
					<Slider
						Grid.Column="0"
						Grid.Row="1"
						Value="{Binding Color_Green, Converter={StaticResource DoubleToIntConverter}}"
						ThumbColor="Green"/>
					<Slider
						Grid.Column="0"
						Grid.Row="2"
						Value="{Binding Color_Blue, Converter={StaticResource DoubleToIntConverter}}"
						ThumbColor="Blue"/>

					<Label
						Grid.Row="0"
						Grid.Column="1"
						VerticalOptions="Center"
						Text="{Binding Color_Red, StringFormat='{0:D3} (0x{0:X02})'}"/>
					<Label
						Grid.Row="1"
						Grid.Column="1"
						VerticalOptions="Center"
						Text="{Binding Color_Green, StringFormat='{0:D3} (0x{0:X02})'}"/>
					<Label
						Grid.Row="2"
						Grid.Column="1"
						VerticalOptions="Center"
						Text="{Binding Color_Blue, StringFormat='{0:D3} (0x{0:X02})'}"/>
				</Grid>
			</Border>
			<Border>
				<VerticalStackLayout Spacing="8">
					<Label
						Text="{loc:Translate Settings_Language}"
						FontSize="Header"/>
					<Picker
						x:Name="LanguagePicker"
						AutomationId="Settings.LanguagePicker"
						SelectedIndexChanged="OnLanguagePickerSelectedIndexChanged"/>
				</VerticalStackLayout>
			</Border>
			<Border>
				<VerticalStackLayout Spacing="8">
					<Label
						Text="{loc:Translate Settings_LocationInterval}"
						FontSize="Header"/>
					<Picker
						x:Name="LocationServiceIntervalPicker"
						ItemsSource="{Binding LocationServiceIntervalItems, Mode=OneTime}"
						SelectedItem="{Binding LocationServiceInterval_Seconds, Mode=TwoWay}"/>
				</VerticalStackLayout>
			</Border>
			<Border>
				<VerticalStackLayout Spacing="8">
					<Label
						Text="{loc:Translate Settings_TimeProgression}"
						FontSize="Header"/>
					<Picker
						x:Name="TimeProgressionRatePicker"
						SelectedIndexChanged="OnTimeProgressionRatePickerSelectedIndexChanged"/>
				</VerticalStackLayout>
			</Border>
			<Border x:Name="AdvancedSettingsBorder">
				<VerticalStackLayout Spacing="8">
					<Label
						Text="{loc:Translate Settings_Advanced}"
						FontSize="Header"/>
					<HorizontalStackLayout
						x:Name="ShowMapWhenLandscapeHeaderLabel"
						HorizontalOptions="End">
						<Label
							Text="{loc:Translate Settings_ShowMapLandscape}"
							Margin="0,0,8,0"
							VerticalOptions="Center"/>
						<Switch
							OnColor="GreenYellow"
							VerticalOptions="Center"
							IsToggled="{Binding ShowMapWhenLandscape}"/>
					</HorizontalStackLayout>
					<HorizontalStackLayout
						x:Name="KeepScreenOnWhenRunningHeaderLabel"
						HorizontalOptions="End">
						<Label
							Text="{loc:Translate Settings_KeepScreenOn}"
							Margin="0,0,8,0"
							VerticalOptions="Center"/>
						<Switch
							OnColor="GreenYellow"
							VerticalOptions="Center"
							IsToggled="{Binding KeepScreenOnWhenRunning}"/>
					</HorizontalStackLayout>
					<HorizontalStackLayout
						HorizontalOptions="End"
						Spacing="8">
						<Label
							Text="{loc:Translate Settings_HorizontalTimetableButtonLabel}"
							VerticalOptions="Center"/>
						<Picker
							x:Name="HorizontalTimetableButtonLabelPicker"
							AutomationId="Settings.HorizontalTimetableButtonLabelPicker"
							VerticalOptions="Center"
							SelectedIndexChanged="OnHorizontalTimetableButtonLabelPickerSelectedIndexChanged"/>
					</HorizontalStackLayout>
				</VerticalStackLayout>
			</Border>
			<Border>
				<VerticalStackLayout Spacing="8">
					<Label
						Text="{loc:Translate Settings_AppTheme}"
						FontSize="Header"/>
					<Picker
						x:Name="AppThemePicker"
						SelectedIndexChanged="OnAppThemePickerSelectedIndexChanged"/>
				</VerticalStackLayout>
			</Border>
			<Border>
				<VerticalStackLayout Spacing="8">
					<Label
						Text="{loc:Translate Settings_PdfEngine}"
						FontSize="Header"/>
					<Label
						Text="{loc:Translate Settings_PdfEngineHint}"
						FontSize="Caption"/>
					<Picker
						x:Name="PdfJsRenderEnginePicker"
						AutomationId="Settings.PdfJsRenderEnginePicker"
						SelectedIndexChanged="OnPdfJsRenderEnginePickerSelectedIndexChanged"/>
					<Label
						x:Name="PdfJsRenderEngineStatusLabel"
						FontSize="Caption"/>
				</VerticalStackLayout>
			</Border>
			<Border>
				<VerticalStackLayout>
					<Label
						Text="{loc:Translate Settings_LogFilePath}"
						FontSize="Header"/>
					<Label
						x:Name="LogFilePathLabel"
						FontSize="Body"/>
				</VerticalStackLayout>
			</Border>
		</VerticalStackLayout>
	</ScrollView>
</ContentPage>
