<?xml version="1.0" encoding="utf-8" ?>
<Grid
	xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
	xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
	xmlns:local="clr-namespace:TRViS"
	xmlns:rootpages="clr-namespace:TRViS.RootPages"
	x:Class="TRViS.RootPages.HomeGridView"
	ColumnDefinitions="3*,4*"
	IsVisible="False"
	Opacity="0"
	InputTransparent="True"
	CascadeInputTransparent="False">

	<Grid.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary Source="StartHomeStyles.xaml"/>
			</ResourceDictionary.MergedDictionaries>
		</ResourceDictionary>
	</Grid.Resources>

	<!-- Loader info card. Title shows loader type ("JSON ファイル", "サーバー接続中" …);
	     detail shows source path/URL set by SetLoader. Glyph swapped in code-behind. -->
	<Border
		x:Name="LoaderInfoCard"
		x:FieldModifier="public"
		Grid.Row="1"
		Grid.ColumnSpan="2"
		Stroke="{x:Static local:RootStyles.BorderStrokeColor}"
		BackgroundColor="{x:Static local:RootStyles.BackgroundBlackWhite}"
		Padding="10,6"
		Margin="20,0,20,4">
		<Border.StrokeShape>
			<RoundRectangle CornerRadius="8"/>
		</Border.StrokeShape>
		<Grid ColumnDefinitions="Auto,*"
					ColumnSpacing="10">
			<Label
				x:Name="LoaderInfoGlyphLabel"
				Grid.Column="0"
				Text="&#xe873;"
				FontFamily="MaterialIconsRegular"
				FontSize="28"
				VerticalOptions="Center"
				TextColor="{x:Static local:RootStyles.TableTextColor}"/>
			<VerticalStackLayout
				Grid.Column="1"
				VerticalOptions="Center">
				<Label
					AutomationId="StartHome.LoaderInfoTitle"
					x:Name="LoaderInfoTitleLabel"
					FontSize="14"
					FontAttributes="Bold"
					TextColor="{x:Static local:RootStyles.TableTextColor}"
					Text="読み込み済みデータ"/>
				<Label
					AutomationId="StartHome.LoaderInfoDetail"
					x:Name="LoaderInfoDetailLabel"
					FontSize="12"
					LineBreakMode="MiddleTruncation"
					TextColor="{x:Static local:RootStyles.TableDetailColor}"
					Text=""/>
				<!-- ダイヤ情報 (サーバーから RequestDiagramInfo の応答 / ブロードキャストで
				     受信)。未受信時は両ラベルとも IsVisible=false で行が潰れる。読み取り専用。 -->
				<Label
					AutomationId="StartHome.DiagramInfoName"
					x:Name="DiagramInfoNameLabel"
					FontSize="13"
					FontAttributes="Bold"
					Margin="0,4,0,0"
					LineBreakMode="TailTruncation"
					TextColor="{x:Static local:RootStyles.TableTextColor}"
					IsVisible="False"
					Text=""/>
				<Label
					AutomationId="StartHome.DiagramInfoDescription"
					x:Name="DiagramInfoDescriptionLabel"
					FontSize="11"
					LineBreakMode="TailTruncation"
					TextColor="{x:Static local:RootStyles.TableDetailColor}"
					IsVisible="False"
					Text=""/>
			</VerticalStackLayout>
		</Grid>
	</Border>

	<!-- Two-step picker (WorkGroup → Work). Each step swaps between
	     a chip (selected name + 変更) and a CollectionView list. Auto-fill: a 1-item
	     list auto-selects when the user hasn't manually cleared.
	     Layout: Rows 0/2 hold the section labels (Auto). Rows 1/3 hold either
	     a chip OR a list border (only one of each pair is IsVisible at a time).
	     Row heights swap between Auto (chip mode) and Star (list mode) in
	     UpdateHomeBodyRowDefinitions, so the visible list naturally fills the
	     remaining height — works for any font scale without pixel arithmetic. -->
	<Grid
		x:Name="HomeBody"
		x:FieldModifier="public"
		AutomationId="StartHome.HomeBody"
		Grid.Row="2"
		Grid.ColumnSpan="2"
		Padding="20,0,20,4"
		RowDefinitions="Auto,*,Auto,Auto"
		ColumnDefinitions="*">

		<Label
			x:Name="WorkGroupSectionLabel"
			Grid.Row="0"
			FontSize="Subtitle"
			Margin="2,8,2,4"
			TextColor="{x:Static local:RootStyles.TableTextColor}"
			Text="Work Group"/>

		<Border
			x:Name="WorkGroupChip"
			Grid.Row="1"
			VerticalOptions="Start"
			AutomationId="StartHome.WorkGroupChip"
			Style="{StaticResource StepChipBorder}"
			IsVisible="False">
			<Border.GestureRecognizers>
				<TapGestureRecognizer Tapped="OnWorkGroupChipTapped"/>
			</Border.GestureRecognizers>
			<Grid ColumnDefinitions="Auto,*,Auto"
						ColumnSpacing="8">
				<!-- &#xe876; = done (selected check) -->
				<Label
					Grid.Column="0"
					Text="&#xe876;"
					FontFamily="MaterialIconsRegular"
					FontSize="18"
					VerticalOptions="Center"
					TextColor="{x:Static local:RootStyles.TableDetailColor}"/>
				<Label
					x:Name="WorkGroupChipNameLabel"
					Grid.Column="1"
					FontSize="15"
					FontAttributes="Bold"
					LineBreakMode="TailTruncation"
					VerticalOptions="Center"
					TextColor="{x:Static local:RootStyles.TableTextColor}"
					Text=""/>
				<Label
					Grid.Column="2"
					Text="変更"
					FontSize="12"
					VerticalOptions="Center"
					TextColor="{x:Static local:RootStyles.TableDetailColor}"/>
			</Grid>
		</Border>

		<!-- Tentative selection is committed to AppViewModel only when 開く is tapped. -->
		<Border
			x:Name="WorkGroupListBorder"
			Grid.Row="1"
			Style="{StaticResource StepListBorder}">
			<CollectionView
				x:Name="WorkGroupListView"
				AutomationId="StartHome.WorkGroupList"
				SelectionMode="Single"
				SelectionChanged="OnWorkGroupSelectionChanged">
				<CollectionView.ItemTemplate>
					<DataTemplate x:DataType="rootpages:WorkGroupListItem">
						<Grid Padding="10,8"
									RowDefinitions="Auto,Auto"
									ColumnDefinitions="*">
							<Label
								Grid.Row="0"
								Text="{Binding Name}"
								FontSize="15"
								FontAttributes="Bold"
								TextColor="{x:Static local:RootStyles.TableTextColor}"/>
							<Label
								Grid.Row="1"
								Text="{Binding Subtitle}"
								FontSize="12"
								TextColor="{x:Static local:RootStyles.TableDetailColor}"/>
						</Grid>
					</DataTemplate>
				</CollectionView.ItemTemplate>
			</CollectionView>
		</Border>

		<Label
			x:Name="WorkSectionLabel"
			Grid.Row="2"
			FontSize="Subtitle"
			Margin="2,8,2,4"
			TextColor="{x:Static local:RootStyles.TableTextColor}"
			Text="Work"/>

		<Border
			x:Name="WorkChip"
			Grid.Row="3"
			VerticalOptions="Start"
			AutomationId="StartHome.WorkChip"
			Style="{StaticResource StepChipBorder}"
			IsVisible="False">
			<Border.GestureRecognizers>
				<TapGestureRecognizer Tapped="OnWorkChipTapped"/>
			</Border.GestureRecognizers>
			<Grid ColumnDefinitions="Auto,*,Auto"
						ColumnSpacing="8">
				<Label
					Grid.Column="0"
					Text="&#xe876;"
					FontFamily="MaterialIconsRegular"
					FontSize="18"
					VerticalOptions="Center"
					TextColor="{x:Static local:RootStyles.TableDetailColor}"/>
				<Label
					x:Name="WorkChipNameLabel"
					Grid.Column="1"
					FontSize="15"
					FontAttributes="Bold"
					LineBreakMode="TailTruncation"
					VerticalOptions="Center"
					TextColor="{x:Static local:RootStyles.TableTextColor}"
					Text=""/>
				<Label
					Grid.Column="2"
					Text="変更"
					FontSize="12"
					VerticalOptions="Center"
					TextColor="{x:Static local:RootStyles.TableDetailColor}"/>
			</Grid>
		</Border>

		<Border
			x:Name="WorkListBorder"
			Grid.Row="3"
			Style="{StaticResource StepListBorder}"
			IsVisible="False">
			<CollectionView
				x:Name="WorkListView"
				AutomationId="StartHome.WorkList"
				SelectionMode="Single"
				SelectionChanged="OnWorkSelectionChanged">
				<CollectionView.ItemTemplate>
					<DataTemplate x:DataType="rootpages:WorkListItem">
						<Grid Padding="10,8"
									RowDefinitions="Auto,Auto"
									ColumnDefinitions="*">
							<Label
								Grid.Row="0"
								Text="{Binding Name}"
								FontSize="15"
								FontAttributes="Bold"
								TextColor="{x:Static local:RootStyles.TableTextColor}"/>
							<Label
								Grid.Row="1"
								Text="{Binding Subtitle}"
								FontSize="12"
								TextColor="{x:Static local:RootStyles.TableDetailColor}"/>
						</Grid>
					</DataTemplate>
				</CollectionView.ItemTemplate>
			</CollectionView>
		</Border>

	</Grid>

	<!-- Disconnect + Open buttons pinned below the picker. -->
	<Grid
		x:Name="HomeButtonsRow"
		x:FieldModifier="public"
		Grid.Row="3"
		Grid.ColumnSpan="2"
		Padding="16,0,16,2"
		ColumnSpacing="8"
		ColumnDefinitions="*,*">
		<Button
			Grid.Column="0"
			AutomationId="StartHome.DisconnectButton"
			x:Name="DisconnectButton"
			Text="閉じる"
			HeightRequest="40"
			CornerRadius="8"
			Clicked="OnDisconnectClicked"/>
		<Button
			Grid.Column="1"
			x:Name="OpenButton"
			AutomationId="StartHome.OpenButton"
			Text="開く"
			HeightRequest="40"
			CornerRadius="8"
			FontAttributes="Bold"
			Clicked="OnOpenClicked"/>
	</Grid>

</Grid>
