<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
	xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
	xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
	xmlns:models="clr-namespace:TRViS.IO.Models;assembly=TRViS.IO.ILoader"
	xmlns:viewmodels="clr-namespace:TRViS.ViewModels"
	xmlns:local="clr-namespace:TRViS"
	BackgroundColor="{x:Static local:RootStyles.BackgroundColor}"
	x:DataType="viewmodels:AppViewModel"
	x:Class="TRViS.RootPages.StartHomePage"
	Title="TRViS">
	<ContentPage.Resources>
		<ResourceDictionary>
			<Style x:Key="PrimaryActionButton"
						 TargetType="Button">
				<Setter Property="HeightRequest"
								Value="80"/>
				<Setter Property="MinimumWidthRequest"
								Value="200"/>
				<Setter Property="FontSize"
								Value="20"/>
				<Setter Property="FontAttributes"
								Value="Bold"/>
				<Setter Property="CornerRadius"
								Value="12"/>
				<Setter Property="Margin"
								Value="6"/>
				<Setter Property="Padding"
								Value="16,8"/>
				<Setter Property="FlexLayout.Grow"
								Value="1"/>
				<Setter Property="FlexLayout.Basis"
								Value="220"/>
			</Style>

			<Style x:Key="SecondaryActionButton"
						 TargetType="Button">
				<Setter Property="FontSize"
								Value="14"/>
				<Setter Property="HeightRequest"
								Value="44"/>
				<Setter Property="CornerRadius"
								Value="8"/>
				<Setter Property="Margin"
								Value="4"/>
				<Setter Property="HorizontalOptions"
								Value="Center"/>
				<Setter Property="MinimumWidthRequest"
								Value="180"/>
			</Style>

			<Style x:Key="LinkButton"
						 TargetType="Button">
				<Setter Property="BackgroundColor"
								Value="Transparent"/>
				<Setter Property="TextColor"
								Value="{x:Static local:RootStyles.TableTextColor}"/>
				<Setter Property="FontSize"
								Value="13"/>
				<Setter Property="Padding"
								Value="8,4"/>
				<Setter Property="Margin"
								Value="4"/>
				<Setter Property="HeightRequest"
								Value="36"/>
			</Style>

			<Style x:Key="HomeListBorder"
						 TargetType="Border">
				<Setter Property="Stroke"
								Value="{x:Static local:RootStyles.BorderStrokeColor}"/>
				<Setter Property="BackgroundColor"
								Value="{x:Static local:RootStyles.BackgroundColor}"/>
				<Setter Property="Margin"
								Value="4"/>
				<Setter Property="Padding"
								Value="8"/>
				<Setter Property="FlexLayout.Basis"
								Value="350"/>
				<Setter Property="FlexLayout.Grow"
								Value="1"/>
			</Style>
		</ResourceDictionary>
	</ContentPage.Resources>

	<Grid x:Name="RootGrid">

		<!-- ========== Animated app header (icon + title) ========== -->
		<!-- VerticalOptions=Start; TranslationY/Scale animated in code-behind to switch between
		     Start (centered, large) and Home (top-anchored, small). -->
		<VerticalStackLayout
			x:Name="AppHeader"
			AutomationId="StartHome.AppHeader"
			VerticalOptions="Start"
			HorizontalOptions="Center"
			Spacing="8"
			Padding="16,32,16,0"
			AnchorY="0"
			AnchorX="0.5">
			<Image
				x:Name="AppIcon"
				AutomationId="StartHome.AppIcon"
				Source="appiconfg.png"
				HeightRequest="160"
				WidthRequest="160"
				Aspect="AspectFit"/>
			<Label
				x:Name="AppTitle"
				AutomationId="StartHome.Title"
				Text="TRViS"
				FontSize="44"
				FontAttributes="Bold"
				HorizontalOptions="Center"
				TextColor="{x:Static local:RootStyles.TableTextColor}"/>
		</VerticalStackLayout>

		<!-- ========== Start body ========== -->
		<Grid
			x:Name="StartBody"
			AutomationId="StartHome.StartBody"
			VerticalOptions="End"
			Padding="24,8,24,24"
			RowSpacing="8">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<!-- Privacy policy reconfirm banner. High-prominence treatment when shown:
			     bigger font, warning glyph, vivid border. Tapping it opens the dialog. -->
			<Border
				x:Name="PrivacyReconfirmBanner"
				AutomationId="StartHome.PrivacyReconfirmBanner"
				Grid.Row="0"
				Stroke="{AppThemeBinding Light=#FF9A00, Dark=#FFB800}"
				StrokeThickness="2"
				BackgroundColor="{AppThemeBinding Light=#FFF4D6, Dark=#3A2400}"
				Padding="16"
				Margin="0,0,0,4"
				IsVisible="False">
				<Border.StrokeShape>
					<RoundRectangle CornerRadius="12"/>
				</Border.StrokeShape>
				<Border.GestureRecognizers>
					<TapGestureRecognizer Tapped="OnPrivacyPolicyClicked"/>
				</Border.GestureRecognizers>
				<Grid ColumnDefinitions="Auto,*,Auto"
							ColumnSpacing="12"
							RowDefinitions="Auto,Auto">
					<!-- &#xe002; = warning, &#xe5cc; = chevron_right (Material Icons) -->
					<Label
						Grid.Column="0"
						Grid.RowSpan="2"
						Text="&#xe002;"
						FontFamily="MaterialIconsRegular"
						FontSize="40"
						TextColor="{AppThemeBinding Light=#A85800, Dark=#FFD05A}"
						VerticalOptions="Center"/>
					<Label
						Grid.Column="1"
						Grid.Row="0"
						AutomationId="StartHome.PrivacyReconfirmText"
						Text="プライバシーポリシーへの同意が必要です"
						TextColor="{AppThemeBinding Light=#5A3500, Dark=#FFE99B}"
						FontSize="18"
						FontAttributes="Bold"/>
					<Label
						Grid.Column="1"
						Grid.Row="1"
						Text="アプリを使用するには、プライバシーポリシーをご確認のうえ同意してください。"
						TextColor="{AppThemeBinding Light=#5A3500, Dark=#FFE99B}"
						FontSize="13"
						LineBreakMode="WordWrap"/>
					<Label
						Grid.Column="2"
						Grid.RowSpan="2"
						Text="&#xe5cc;"
						FontFamily="MaterialIconsRegular"
						FontSize="32"
						TextColor="{AppThemeBinding Light=#A85800, Dark=#FFD05A}"
						VerticalOptions="Center"/>
				</Grid>
			</Border>

			<!-- Two main buttons: orientation-aware (vertical on portrait, horizontal on landscape).
			     IsEnabled is bound to IsPrivacyPolicyAccepted in code-behind. -->
			<FlexLayout
				x:Name="PrimaryButtons"
				Grid.Row="1"
				Direction="Row"
				Wrap="Wrap"
				JustifyContent="Center"
				AlignItems="Center">
				<Button
					x:Name="ConnectServerButton"
					AutomationId="StartHome.ConnectServerButton"
					Text="サーバーから読み込み"
					Style="{StaticResource PrimaryActionButton}"
					Clicked="OnConnectServerClicked"/>
				<Button
					x:Name="SelectFileButton"
					AutomationId="StartHome.SelectFileButton"
					Text="ファイルを選択"
					Style="{StaticResource PrimaryActionButton}"
					Clicked="OnSelectFileClicked"/>
			</FlexLayout>

			<!-- Demo data (smaller) -->
			<Button
				x:Name="LoadDemoButton"
				Grid.Row="2"
				AutomationId="StartHome.LoadDemoButton"
				Text="デモデータで開始"
				Style="{StaticResource SecondaryActionButton}"
				Clicked="OnLoadDemoClicked"/>

			<!-- Footer links: Privacy / TPL -->
			<HorizontalStackLayout
				Grid.Row="3"
				HorizontalOptions="Center"
				Spacing="4">
				<Button
					AutomationId="StartHome.PrivacyPolicyButton"
					Text="プライバシーポリシー"
					Style="{StaticResource LinkButton}"
					Clicked="OnPrivacyPolicyClicked"/>
				<Label
					Text="·"
					VerticalOptions="Center"
					TextColor="{x:Static local:RootStyles.TableDetailColor}"/>
				<Button
					AutomationId="StartHome.ThirdPartyLicensesButton"
					Text="Third Party Licenses"
					Style="{StaticResource LinkButton}"
					Clicked="OnThirdPartyLicensesClicked"/>
			</HorizontalStackLayout>

			<!-- DEBUG/UI_TEST seam buttons (zero-sized, toggled visible in code-behind under #if UI_TEST). -->
			<Button
				x:Name="TestSeedButton"
				AutomationId="StartHome.TestSeedButton"
				Grid.Row="3"
				IsVisible="False"
				HeightRequest="1"
				WidthRequest="1"
				Padding="0"
				Margin="0"
				Clicked="TestSeedButton_Clicked"/>
			<Button
				x:Name="TestSeedGpsButton"
				AutomationId="StartHome.TestSeedGpsButton"
				Grid.Row="3"
				IsVisible="False"
				HeightRequest="1"
				WidthRequest="1"
				Padding="0"
				Margin="0"
				Clicked="TestSeedGpsButton_Clicked"/>
		</Grid>

		<!-- ========== Home body ========== -->
		<!-- IsVisible/Opacity animated in code-behind. The first row is an invisible spacer
		     whose HeightRequest is sized to the scaled header in code-behind so the body
		     content never collides with the header (replaces a hard-coded 160 px padding). -->
		<Grid
			x:Name="HomeBody"
			AutomationId="StartHome.HomeBody"
			Padding="16,0,16,16"
			RowSpacing="8"
			IsVisible="False"
			Opacity="0">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<!-- Spacer reserving space for the small (scaled) app header in Home mode.
			     HeightRequest is set in code-behind from the measured AppHeader size. -->
			<BoxView
				x:Name="HomeBodyTopSpacer"
				Grid.Row="0"
				HeightRequest="120"
				Color="Transparent"/>

			<!-- Connection/file info card placeholder (Phase 4 polishes content). -->
			<Border
				Grid.Row="1"
				Stroke="{x:Static local:RootStyles.BorderStrokeColor}"
				BackgroundColor="{x:Static local:RootStyles.BackgroundColor}"
				Padding="12"
				Margin="4,0">
				<Border.StrokeShape>
					<RoundRectangle CornerRadius="8"/>
				</Border.StrokeShape>
				<VerticalStackLayout Spacing="2">
					<Label
						AutomationId="StartHome.LoaderInfoTitle"
						x:Name="LoaderInfoTitleLabel"
						FontSize="14"
						FontAttributes="Bold"
						TextColor="{x:Static local:RootStyles.TableTextColor}"
						Text="読み込み済みデータ"/>
					<Label
						AutomationId="StartHome.LoaderInfoDetail"
						x:Name="LoaderInfoDetailLabel"
						FontSize="12"
						TextColor="{x:Static local:RootStyles.TableDetailColor}"
						Text=""/>
				</VerticalStackLayout>
			</Border>

			<!-- WorkGroup / Work selection (existing CollectionViews; minimization comes in Phase 4) -->
			<FlexLayout
				Grid.Row="2"
				Wrap="Wrap">
				<Border Style="{StaticResource HomeListBorder}">
					<Grid RowDefinitions="40,*">
						<Label
							Grid.Row="0"
							FontSize="Subtitle"
							TextColor="{x:Static local:RootStyles.TableTextColor}"
							Text="Work Group"/>
						<CollectionView
							AutomationId="StartHome.WorkGroupList"
							Grid.Row="1"
							ItemsSource="{Binding WorkGroupList}"
							SelectedItem="{Binding SelectedWorkGroup, Mode=TwoWay}"
							SelectionMode="Single">
							<CollectionView.ItemTemplate>
								<DataTemplate x:DataType="models:WorkGroup">
									<Grid Padding="8,6">
										<Label
											Text="{Binding Name}"
											TextColor="{x:Static local:RootStyles.TableTextColor}"
											VerticalTextAlignment="Center"/>
									</Grid>
								</DataTemplate>
							</CollectionView.ItemTemplate>
						</CollectionView>
					</Grid>
				</Border>

				<Border Style="{StaticResource HomeListBorder}">
					<Grid RowDefinitions="40,*">
						<Label
							Grid.Row="0"
							FontSize="Subtitle"
							TextColor="{x:Static local:RootStyles.TableTextColor}"
							Text="Work"/>
						<CollectionView
							AutomationId="StartHome.WorkList"
							Grid.Row="1"
							ItemsSource="{Binding WorkList}"
							SelectedItem="{Binding SelectedWork, Mode=TwoWay}"
							SelectionMode="Single">
							<CollectionView.ItemTemplate>
								<DataTemplate x:DataType="models:Work">
									<Grid Padding="8,6">
										<Label
											Text="{Binding Name}"
											TextColor="{x:Static local:RootStyles.TableTextColor}"
											VerticalTextAlignment="Center"/>
									</Grid>
								</DataTemplate>
							</CollectionView.ItemTemplate>
						</CollectionView>
					</Grid>
				</Border>
			</FlexLayout>

			<!-- Open / Disconnect buttons -->
			<Grid
				Grid.Row="3"
				ColumnSpacing="8"
				ColumnDefinitions="*,*">
				<Button
					Grid.Column="0"
					AutomationId="StartHome.DisconnectButton"
					x:Name="DisconnectButton"
					Text="閉じる"
					HeightRequest="56"
					CornerRadius="8"
					Clicked="OnDisconnectClicked"/>
				<Button
					Grid.Column="1"
					AutomationId="StartHome.OpenButton"
					Text="開く"
					HeightRequest="56"
					CornerRadius="8"
					FontAttributes="Bold"
					Clicked="OnOpenClicked"/>
			</Grid>
		</Grid>

	</Grid>
</ContentPage>
