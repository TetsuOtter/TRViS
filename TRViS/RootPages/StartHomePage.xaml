<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
	xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
	xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
	xmlns:viewmodels="clr-namespace:TRViS.ViewModels"
	xmlns:rootpages="clr-namespace:TRViS.RootPages"
	xmlns:local="clr-namespace:TRViS"
	BackgroundColor="{x:Static local:RootStyles.BackgroundColor}"
	x:DataType="viewmodels:AppViewModel"
	x:Class="TRViS.RootPages.StartHomePage"
	Title="TRViS">
	<ContentPage.Resources>
		<ResourceDictionary>
			<Style x:Key="PrimaryActionButton"
						 TargetType="Button">
				<Setter Property="HeightRequest"
								Value="80"/>
				<Setter Property="MinimumWidthRequest"
								Value="200"/>
				<Setter Property="FontSize"
								Value="20"/>
				<Setter Property="FontAttributes"
								Value="Bold"/>
				<Setter Property="CornerRadius"
								Value="12"/>
				<Setter Property="Margin"
								Value="6"/>
				<Setter Property="Padding"
								Value="16,8"/>
				<Setter Property="FlexLayout.Grow"
								Value="1"/>
				<Setter Property="FlexLayout.Basis"
								Value="220"/>
			</Style>

			<Style x:Key="SecondaryActionButton"
						 TargetType="Button">
				<Setter Property="FontSize"
								Value="14"/>
				<Setter Property="HeightRequest"
								Value="44"/>
				<Setter Property="CornerRadius"
								Value="8"/>
				<Setter Property="Margin"
								Value="4"/>
				<Setter Property="HorizontalOptions"
								Value="Center"/>
				<Setter Property="MinimumWidthRequest"
								Value="180"/>
			</Style>

			<Style x:Key="LinkButton"
						 TargetType="Button">
				<Setter Property="BackgroundColor"
								Value="Transparent"/>
				<Setter Property="TextColor"
								Value="{x:Static local:RootStyles.TableTextColor}"/>
				<Setter Property="FontSize"
								Value="13"/>
				<Setter Property="Padding"
								Value="8,4"/>
				<Setter Property="Margin"
								Value="2,0"/>
				<Setter Property="HeightRequest"
								Value="32"/>
			</Style>

			<Style x:Key="StepListBorder"
						 TargetType="Border">
				<Setter Property="Stroke"
								Value="{x:Static local:RootStyles.BorderStrokeColor}"/>
				<Setter Property="BackgroundColor"
								Value="{x:Static local:RootStyles.BackgroundColor}"/>
				<Setter Property="Margin"
								Value="0,0,0,4"/>
				<Setter Property="Padding"
								Value="8"/>
				<Setter Property="StrokeShape">
					<RoundRectangle CornerRadius="8"/>
				</Setter>
			</Style>

			<Style x:Key="StepChipBorder"
						 TargetType="Border">
				<Setter Property="Stroke"
								Value="{x:Static local:RootStyles.BorderStrokeColor}"/>
				<Setter Property="StrokeThickness"
								Value="1"/>
				<Setter Property="BackgroundColor"
								Value="{x:Static local:RootStyles.BackgroundBlackWhite}"/>
				<Setter Property="Margin"
								Value="0,0,0,4"/>
				<Setter Property="Padding"
								Value="12,8"/>
				<Setter Property="StrokeShape">
					<RoundRectangle CornerRadius="8"/>
				</Setter>
			</Style>
		</ResourceDictionary>
	</ContentPage.Resources>

	<!-- Three-layer stack (RootGrid is a 1-cell wrapper, layers overlap at z-order):
	       1) BackgroundGrid — always visible. Owns AppHeader, FooterLinks, TestSeamHost,
	          and size-mirror placeholders for the elements that live in StartGrid/HomeGrid.
	          RowDefinitions swap between Start (*,0,Auto,0,Auto) and Home
	          (<HOME_HEADER_ROW_HEIGHT>,Auto,*,Auto,Auto) so AppHeader's row aligns with
	          the body layers.
	       2) StartGrid — visible only in Start mode. Fixed RowDefinitions matching
	          BackgroundGrid's Start mode. Owns StartBody.
	       3) HomeGrid — visible only in Home mode. Fixed RowDefinitions matching
	          BackgroundGrid's Home mode. Owns LoaderInfoCard, HomeBody, HomeButtonsRow.
	     Cross-grid alignment is preserved via BoxView size-mirror placeholders that
	     bind HeightRequest / Margin to the real elements in the sibling grids. -->
	<Grid x:Name="RootGrid">

		<!-- ========== Background layer ========== -->
		<!-- RowDefinitions are assigned in code-behind from the static readonly
		     PortraitStartRows / PortraitHomeRows / LandscapePhoneRows so there is a
		     single source of truth. -->
		<Grid x:Name="BackgroundGrid"
					ColumnDefinitions="*,*">

			<!-- Animated app header (icon + title). VerticalOptions=Center centers it
			     inside Row 0 (* in Start mode, fixed HOME_HEADER_ROW_HEIGHT in Home mode). -->
			<VerticalStackLayout
				x:Name="AppHeader"
				AutomationId="StartHome.AppHeader"
				Grid.Row="0"
				Grid.ColumnSpan="2"
				VerticalOptions="Center"
				HorizontalOptions="Center"
				Spacing="8"
				Padding="16,32,16,0"
				AnchorY="0"
				AnchorX="0.5">
				<Image
					x:Name="AppIcon"
					AutomationId="StartHome.AppIcon"
					Source="appiconfg.png"
					HeightRequest="160"
					WidthRequest="160"
					Aspect="AspectFit"/>
				<Label
					x:Name="AppTitle"
					AutomationId="StartHome.Title"
					Text="TRViS"
					FontSize="44"
					FontAttributes="Bold"
					HorizontalOptions="Center"
					TextColor="{x:Static local:RootStyles.TableTextColor}"/>
			</VerticalStackLayout>

			<!-- Footer links: Privacy / TPL pinned to the bottom. Lives in the
			     background so both Start and Home modes share it. Rows 1, 2, 3 of
			     the background hold no content — their sizes come from the shared
			     RowDefinitionCollections (fixed pixel heights) so they align with
			     the matching slots in StartGrid / HomeGrid without needing
			     size-mirror placeholders. -->
			<HorizontalStackLayout
				x:Name="FooterLinks"
				Grid.Row="4"
				Grid.ColumnSpan="2"
				HorizontalOptions="Center"
				Padding="0,0"
				Spacing="4">
				<Button
					AutomationId="StartHome.PrivacyPolicyButton"
					Text="プライバシーポリシー"
					Style="{StaticResource LinkButton}"
					Clicked="OnPrivacyPolicyClicked"/>
				<Label
					Text="·"
					VerticalOptions="Center"
					TextColor="{x:Static local:RootStyles.TableDetailColor}"/>
				<Button
					AutomationId="StartHome.ThirdPartyLicensesButton"
					Text="Third Party Licenses"
					Style="{StaticResource LinkButton}"
					Clicked="OnThirdPartyLicensesClicked"/>
			</HorizontalStackLayout>

			<!-- UI_TEST seam buttons. Each button has its own 24px row of an explicit
			     Grid (no StackLayout pass that may collapse 1×1 children on Mac Catalyst).
			     In production the Click handlers are no-ops (gated on #if UI_TEST). -->
			<Grid
				x:Name="TestSeamHost"
				Grid.Row="0"
				HorizontalOptions="Start"
				VerticalOptions="Start"
				RowDefinitions="24,24,24,24,24,24,24,24,24,24,24"
				ColumnDefinitions="24"
				RowSpacing="0"
				ColumnSpacing="0"
				Padding="0"
				Margin="0">
				<Button
					x:Name="TestSeedButton"
					AutomationId="StartHome.TestSeedButton"
					Grid.Row="0"
					BackgroundColor="Transparent"
					BorderColor="Transparent"
					Padding="0"
					Margin="0"
					Clicked="TestSeedButton_Clicked"/>
				<Button
					x:Name="TestSeedGpsButton"
					AutomationId="StartHome.TestSeedGpsButton"
					Grid.Row="1"
					BackgroundColor="Transparent"
					BorderColor="Transparent"
					Padding="0"
					Margin="0"
					Clicked="TestSeedGpsButton_Clicked"/>
				<Button
					x:Name="TestAutoOpenButton"
					AutomationId="StartHome.TestAutoOpenButton"
					Grid.Row="2"
					BackgroundColor="Transparent"
					BorderColor="Transparent"
					Padding="0"
					Margin="0"
					Clicked="TestAutoOpenButton_Clicked"/>
				<Button
					x:Name="TestClearHistoryButton"
					AutomationId="StartHome.TestClearHistoryButton"
					Grid.Row="3"
					BackgroundColor="Transparent"
					BorderColor="Transparent"
					Padding="0"
					Margin="0"
					Clicked="TestClearHistoryButton_Clicked"/>
				<Button
					x:Name="TestSeedSqliteButton"
					AutomationId="StartHome.TestSeedSqliteButton"
					Grid.Row="4"
					BackgroundColor="Transparent"
					BorderColor="Transparent"
					Padding="0"
					Margin="0"
					Clicked="TestSeedSqliteButton_Clicked"/>
				<Button
					x:Name="TestClearTimetablesButton"
					AutomationId="StartHome.TestClearTimetablesButton"
					Grid.Row="5"
					BackgroundColor="Transparent"
					BorderColor="Transparent"
					Padding="0"
					Margin="0"
					Clicked="TestClearTimetablesButton_Clicked"/>
				<Button
					x:Name="TestSeedSampleFilesButton"
					AutomationId="StartHome.TestSeedSampleFilesButton"
					Grid.Row="6"
					BackgroundColor="Transparent"
					BorderColor="Transparent"
					Padding="0"
					Margin="0"
					Clicked="TestSeedSampleFilesButton_Clicked"/>
				<Button
					x:Name="TestClearSampleFilesButton"
					AutomationId="StartHome.TestClearSampleFilesButton"
					Grid.Row="7"
					BackgroundColor="Transparent"
					BorderColor="Transparent"
					Padding="0"
					Margin="0"
					Clicked="TestClearSampleFilesButton_Clicked"/>
				<Button
					x:Name="TestSetupBrowseFallbackButton"
					AutomationId="StartHome.TestSetupBrowseFallbackButton"
					Grid.Row="8"
					BackgroundColor="Transparent"
					BorderColor="Transparent"
					Padding="0"
					Margin="0"
					Clicked="TestSetupBrowseFallbackButton_Clicked"/>
				<Button
					x:Name="TestSeedNextTrainSelectionButton"
					AutomationId="StartHome.TestSeedNextTrainSelectionButton"
					Grid.Row="9"
					BackgroundColor="Transparent"
					BorderColor="Transparent"
					Padding="0"
					Margin="0"
					Clicked="TestSeedNextTrainSelectionButton_Clicked"/>
				<Button
					x:Name="TestSeedHorizontalTimetableButton"
					AutomationId="StartHome.TestSeedHorizontalTimetableButton"
					Grid.Row="10"
					BackgroundColor="Transparent"
					BorderColor="Transparent"
					Padding="0"
					Margin="0"
					Clicked="TestSeedHorizontalTimetableButton_Clicked"/>
			</Grid>
		</Grid>

		<!-- ========== Start layer ========== -->
		<!-- Shares PortraitStartRows with BackgroundGrid (in Start mode) so StartBody
		     (Row 2) aligns with the AppHeader+Footer slots in the background layer.
		     Visibility flipped by code-behind. -->
		<Grid x:Name="StartGrid"
					ColumnDefinitions="*,*"
					InputTransparent="False"
					CascadeInputTransparent="False">

			<Grid
				x:Name="StartBody"
				AutomationId="StartHome.StartBody"
				Grid.Row="2"
				Grid.ColumnSpan="2"
				Padding="24,8,24,24"
				RowSpacing="8">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<!-- Row 0 hosts both the primary buttons and the privacy reconfirm banner
				     in the same cell. The banner z-orders on top (declared later) and stretches
				     to Fill so it fully covers the buttons when visible. -->
				<Grid Grid.Row="0">
					<FlexLayout
						x:Name="PrimaryButtons"
						Direction="Row"
						Wrap="Wrap"
						JustifyContent="Center"
						AlignItems="Center">
						<Button
							x:Name="ConnectServerButton"
							AutomationId="StartHome.ConnectServerButton"
							Text="サーバーから読み込み"
							Style="{StaticResource PrimaryActionButton}"
							Clicked="OnConnectServerClicked"/>
						<Button
							x:Name="SelectFileButton"
							AutomationId="StartHome.SelectFileButton"
							Text="ファイルを選択"
							Style="{StaticResource PrimaryActionButton}"
							Clicked="OnSelectFileClicked"/>
					</FlexLayout>

					<!-- IsVisible is controlled exclusively from code-behind
					     (UpdatePrivacyDependentControls). Do NOT set IsVisible="False"
					     in XAML: on Windows MAUI a Border that starts collapsed never
					     gets a UIA peer, so the runtime flip to true is invisible to
					     Appium. -->
					<Border
						x:Name="PrivacyReconfirmBanner"
						AutomationId="StartHome.PrivacyReconfirmBanner"
						HorizontalOptions="Fill"
						VerticalOptions="Fill"
						Stroke="{AppThemeBinding Light=#FF9A00, Dark=#FFB800}"
						StrokeThickness="2"
						BackgroundColor="{AppThemeBinding Light=#FFF4D6, Dark=#3A2400}"
						Padding="16">
						<Border.StrokeShape>
							<RoundRectangle CornerRadius="12"/>
						</Border.StrokeShape>
						<Border.GestureRecognizers>
							<TapGestureRecognizer Tapped="OnPrivacyPolicyClicked"/>
						</Border.GestureRecognizers>
						<Grid ColumnDefinitions="Auto,*,Auto"
									ColumnSpacing="12"
									RowDefinitions="Auto,Auto"
									VerticalOptions="Center">
							<!-- &#xe002; = warning, &#xe5cc; = chevron_right (Material Icons) -->
							<Label
								Grid.Column="0"
								Grid.RowSpan="2"
								Text="&#xe002;"
								FontFamily="MaterialIconsRegular"
								FontSize="40"
								TextColor="{AppThemeBinding Light=#A85800, Dark=#FFD05A}"
								VerticalOptions="Center"/>
							<Label
								Grid.Column="1"
								Grid.Row="0"
								AutomationId="StartHome.PrivacyReconfirmText"
								Text="プライバシーポリシーへの同意が必要です"
								TextColor="{AppThemeBinding Light=#5A3500, Dark=#FFE99B}"
								FontSize="18"
								FontAttributes="Bold"/>
							<Label
								Grid.Column="1"
								Grid.Row="1"
								Text="アプリを使用するには、プライバシーポリシーをご確認のうえ同意してください。"
								TextColor="{AppThemeBinding Light=#5A3500, Dark=#FFE99B}"
								FontSize="13"
								LineBreakMode="WordWrap"/>
							<Label
								Grid.Column="2"
								Grid.RowSpan="2"
								Text="&#xe5cc;"
								FontFamily="MaterialIconsRegular"
								FontSize="32"
								TextColor="{AppThemeBinding Light=#A85800, Dark=#FFD05A}"
								VerticalOptions="Center"/>
						</Grid>
					</Border>
				</Grid>

				<Button
					x:Name="LoadDemoButton"
					Grid.Row="1"
					AutomationId="StartHome.LoadDemoButton"
					Text="デモデータで開始"
					Style="{StaticResource SecondaryActionButton}"
					Clicked="OnLoadDemoClicked"/>

			</Grid>

		</Grid>

		<!-- ========== Home layer ========== -->
		<!-- Shares PortraitHomeRows with BackgroundGrid (in Home mode). Visibility
		     flipped by code-behind. -->
		<Grid x:Name="HomeGrid"
					ColumnDefinitions="*,*"
					IsVisible="False"
					Opacity="0"
					InputTransparent="False"
					CascadeInputTransparent="False">

			<!-- Loader info card. Title shows loader type ("JSON ファイル", "サーバー接続中" …);
			     detail shows source path/URL set by SetLoader. Glyph swapped in code-behind. -->
			<Border
				x:Name="LoaderInfoCard"
				Grid.Row="1"
				Grid.ColumnSpan="2"
				Stroke="{x:Static local:RootStyles.BorderStrokeColor}"
				BackgroundColor="{x:Static local:RootStyles.BackgroundBlackWhite}"
				Padding="12"
				Margin="20,0,20,8">
				<Border.StrokeShape>
					<RoundRectangle CornerRadius="8"/>
				</Border.StrokeShape>
				<Grid ColumnDefinitions="Auto,*"
							ColumnSpacing="10"
							RowDefinitions="Auto,Auto">
					<Label
						x:Name="LoaderInfoGlyphLabel"
						Grid.Column="0"
						Grid.RowSpan="2"
						Text="&#xe873;"
						FontFamily="MaterialIconsRegular"
						FontSize="28"
						VerticalOptions="Center"
						TextColor="{x:Static local:RootStyles.TableTextColor}"/>
					<Label
						AutomationId="StartHome.LoaderInfoTitle"
						x:Name="LoaderInfoTitleLabel"
						Grid.Column="1"
						Grid.Row="0"
						FontSize="14"
						FontAttributes="Bold"
						TextColor="{x:Static local:RootStyles.TableTextColor}"
						Text="読み込み済みデータ"/>
					<Label
						AutomationId="StartHome.LoaderInfoDetail"
						x:Name="LoaderInfoDetailLabel"
						Grid.Column="1"
						Grid.Row="1"
						FontSize="12"
						LineBreakMode="MiddleTruncation"
						TextColor="{x:Static local:RootStyles.TableDetailColor}"
						Text=""/>
				</Grid>
			</Border>

			<!-- Two-step picker (WorkGroup → Work). Each step swaps between
			     a chip (selected name + 変更) and a CollectionView list. Auto-fill: a 1-item
			     list auto-selects when the user hasn't manually cleared. -->
			<Grid
				x:Name="HomeBody"
				AutomationId="StartHome.HomeBody"
				Grid.Row="2"
				Grid.ColumnSpan="2"
				Padding="16,0,16,4">

				<ScrollView>
					<VerticalStackLayout Padding="4,0"
							Spacing="0">

						<Label
							x:Name="WorkGroupSectionLabel"
							FontSize="Subtitle"
							Margin="2,8,2,4"
							TextColor="{x:Static local:RootStyles.TableTextColor}"
							Text="Work Group"/>

						<Border
							x:Name="WorkGroupChip"
							AutomationId="StartHome.WorkGroupChip"
							Style="{StaticResource StepChipBorder}"
							IsVisible="False">
							<Border.GestureRecognizers>
								<TapGestureRecognizer Tapped="OnWorkGroupChipTapped"/>
							</Border.GestureRecognizers>
							<Grid ColumnDefinitions="Auto,*,Auto"
										ColumnSpacing="8">
								<!-- &#xe876; = done (selected check) -->
								<Label
									Grid.Column="0"
									Text="&#xe876;"
									FontFamily="MaterialIconsRegular"
									FontSize="18"
									VerticalOptions="Center"
									TextColor="{x:Static local:RootStyles.TableDetailColor}"/>
								<Label
									x:Name="WorkGroupChipNameLabel"
									Grid.Column="1"
									FontSize="15"
									FontAttributes="Bold"
									LineBreakMode="TailTruncation"
									VerticalOptions="Center"
									TextColor="{x:Static local:RootStyles.TableTextColor}"
									Text=""/>
								<Label
									Grid.Column="2"
									Text="変更"
									FontSize="12"
									VerticalOptions="Center"
									TextColor="{x:Static local:RootStyles.TableDetailColor}"/>
							</Grid>
						</Border>

						<!-- Tentative selection is committed to AppViewModel only when 開く is tapped. -->
						<Border
							x:Name="WorkGroupListBorder"
							Style="{StaticResource StepListBorder}">
							<CollectionView
								x:Name="WorkGroupListView"
								AutomationId="StartHome.WorkGroupList"
								HeightRequest="160"
								SelectionMode="Single"
								SelectionChanged="OnWorkGroupSelectionChanged">
								<CollectionView.ItemTemplate>
									<DataTemplate x:DataType="rootpages:WorkGroupListItem">
										<Grid Padding="10,8"
													RowDefinitions="Auto,Auto"
													ColumnDefinitions="*">
											<Label
												Grid.Row="0"
												Text="{Binding Name}"
												FontSize="15"
												FontAttributes="Bold"
												TextColor="{x:Static local:RootStyles.TableTextColor}"/>
											<Label
												Grid.Row="1"
												Text="{Binding Subtitle}"
												FontSize="12"
												TextColor="{x:Static local:RootStyles.TableDetailColor}"/>
										</Grid>
									</DataTemplate>
								</CollectionView.ItemTemplate>
							</CollectionView>
						</Border>

						<Label
							x:Name="WorkSectionLabel"
							FontSize="Subtitle"
							Margin="2,8,2,4"
							TextColor="{x:Static local:RootStyles.TableTextColor}"
							Text="Work"/>

						<Border
							x:Name="WorkChip"
							AutomationId="StartHome.WorkChip"
							Style="{StaticResource StepChipBorder}"
							IsVisible="False">
							<Border.GestureRecognizers>
								<TapGestureRecognizer Tapped="OnWorkChipTapped"/>
							</Border.GestureRecognizers>
							<Grid ColumnDefinitions="Auto,*,Auto"
										ColumnSpacing="8">
								<Label
									Grid.Column="0"
									Text="&#xe876;"
									FontFamily="MaterialIconsRegular"
									FontSize="18"
									VerticalOptions="Center"
									TextColor="{x:Static local:RootStyles.TableDetailColor}"/>
								<Label
									x:Name="WorkChipNameLabel"
									Grid.Column="1"
									FontSize="15"
									FontAttributes="Bold"
									LineBreakMode="TailTruncation"
									VerticalOptions="Center"
									TextColor="{x:Static local:RootStyles.TableTextColor}"
									Text=""/>
								<Label
									Grid.Column="2"
									Text="変更"
									FontSize="12"
									VerticalOptions="Center"
									TextColor="{x:Static local:RootStyles.TableDetailColor}"/>
							</Grid>
						</Border>

						<Border
							x:Name="WorkListBorder"
							Style="{StaticResource StepListBorder}"
							IsVisible="False">
							<CollectionView
								x:Name="WorkListView"
								AutomationId="StartHome.WorkList"
								HeightRequest="160"
								SelectionMode="Single"
								SelectionChanged="OnWorkSelectionChanged">
								<CollectionView.ItemTemplate>
									<DataTemplate x:DataType="rootpages:WorkListItem">
										<Grid Padding="10,8"
													RowDefinitions="Auto,Auto"
													ColumnDefinitions="*">
											<Label
												Grid.Row="0"
												Text="{Binding Name}"
												FontSize="15"
												FontAttributes="Bold"
												TextColor="{x:Static local:RootStyles.TableTextColor}"/>
											<Label
												Grid.Row="1"
												Text="{Binding Subtitle}"
												FontSize="12"
												TextColor="{x:Static local:RootStyles.TableDetailColor}"/>
										</Grid>
									</DataTemplate>
								</CollectionView.ItemTemplate>
							</CollectionView>
						</Border>

					</VerticalStackLayout>
				</ScrollView>

			</Grid>

			<!-- Disconnect + Open buttons pinned below the picker. -->
			<Grid
				x:Name="HomeButtonsRow"
				Grid.Row="3"
				Grid.ColumnSpan="2"
				Padding="16,0,16,8"
				ColumnSpacing="8"
				ColumnDefinitions="*,*">
				<Button
					Grid.Column="0"
					AutomationId="StartHome.DisconnectButton"
					x:Name="DisconnectButton"
					Text="閉じる"
					HeightRequest="40"
					CornerRadius="8"
					Clicked="OnDisconnectClicked"/>
				<Button
					Grid.Column="1"
					x:Name="OpenButton"
					AutomationId="StartHome.OpenButton"
					Text="開く"
					HeightRequest="40"
					CornerRadius="8"
					FontAttributes="Bold"
					Clicked="OnOpenClicked"/>
			</Grid>

		</Grid>

	</Grid>
</ContentPage>
